@{
    ViewData["Title"] = "Архив организаций";
    var omsus = ViewBag.Omsus as IEnumerable<main_project.Models.OMSU> ?? Array.Empty<main_project.Models.OMSU>();
}

@await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
<link rel="stylesheet" href="~/css/pages/admin-archives.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/pages/omsu.css" asp-append-version="true" />

<div class="content archive-page omsu-page" id="default_content">
    <a class="back-button archive-back-button" href="/organizations">← Вернуться к списку организаций</a>

    <div class="note">
        <h2>Список архивных организаций</h2>
        <p>Ниже представлена таблица с архивными организациями</p>
    </div>

    @await Html.PartialAsync("~/Views/OMSU/Partials/_ArchiveOmsuTable.cshtml", omsus)
</div>
