@model IEnumerable<main_project.Models.OMSU>
@{
    var omsus = Model ?? (ViewBag.Omsus as IEnumerable<main_project.Models.OMSU>) ?? Enumerable.Empty<main_project.Models.OMSU>();
}

<div class="content omsu-page omsu-page--archive" id="default_content" data-page="omsu-archive">
    <p class="back-button omsu-page__back" onclick="handleTabClick('get_omsu')">← Вернуться к списку организаций</p>

    <div class="note omsu-page__note">
        <h2>Список архивных организаций</h2>
        <p>Ниже представлена таблица с архивными организациями</p>
    </div>

    @await Html.PartialAsync("Partials/_ArchiveOmsuTable", omsus)
</div>
