@{
    ViewData["Title"] = "Список организаций";
    var omsus = ViewBag.Omsus as IEnumerable<main_project.Models.OMSU> ?? Array.Empty<main_project.Models.OMSU>();
}

@await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
<link rel="stylesheet" href="~/css/pages/omsu.css" asp-append-version="true" />

<div class="content omsu-page" id="default_content" data-page="omsu-list">
    <div class="note">
        <h2>Список организаций</h2>
        <p>Ниже представлена таблица с существующими организациями</p>
    </div>

    @await Html.PartialAsync("~/Views/OMSU/Partials/_OmsuToolbar.cshtml")
    @await Html.PartialAsync("~/Views/OMSU/Partials/_OmsuTable.cshtml", omsus)
</div>

@await Html.PartialAsync("~/Views/OMSU/Partials/_EditOmsuModal.cshtml")

<script src="~/js/pages/omsu.js" asp-append-version="true"></script>
