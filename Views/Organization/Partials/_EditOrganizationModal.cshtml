<div id="editOrganizationModal" class="modal organization-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Редактирование организации</h2>
            <button type="button" class="modal-close" data-modal-close="editOrganizationModal"><i class="fas fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="editOrganizationId">
            <div class="form-group">
                <label>Название организации:</label>
                <input type="text" id="organizationName" class="form-control">
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="organizationEmail" class="form-control">
            </div>
            <div class="form-group">
                <label>Дата начала:</label>
                <input type="date" id="organizationDateBegin" class="form-control">
            </div>
            <div class="form-group">
                <label>Дата окончания:</label>
                <input type="date" id="organizationDateEnd" class="form-control">
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" id="saveOrganizationBtn" data-click-call="updateOrganization" class="modal_btn modal_btn-primary">Сохранить</button>
            <button type="button" data-modal-close="editOrganizationModal" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>
