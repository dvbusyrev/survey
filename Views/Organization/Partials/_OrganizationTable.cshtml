@model IEnumerable<MainProject.Models.Organization>

<table id="data_table" class="organization-table">
    <thead>
        <tr class='table_tr'>
            <th class="organization-table__th--start">Название организации</th>
            <th>Дата начала</th>
            <th>Дата окончания</th>
            <th>Доступные анкеты</th>
            <th>Email</th>
            <th class="organization-table__th--end">Действия</th>
        </tr>
    </thead>
    <tbody id="organizationTableBody">
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="6" class="table-empty-cell">Результаты не найдены!</td>
            </tr>
        }
        else
        {
            foreach (var organization in Model)
            {
                var encodedName = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(organization.OrganizationName ?? "");
                var encodedEmail = System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(organization.Email ?? "");
                <tr>
                    <td>@organization.OrganizationName</td>
                    <td>@(organization.DateBegin?.ToString("dd.MM.yyyy") ?? "")</td>
                    <td>@(organization.DateEnd?.ToString("dd.MM.yyyy") ?? "")</td>
                    @if (organization.SurveyNames == "Не указано")
                    {
                        <td class="organization-table__empty-surveys">@organization.SurveyNames</td>
                    }
                    else
                    {
                        <td>@organization.SurveyNames</td>
                    }
                    <td>@organization.Email</td>
                    <td class="action-icons">
                        <div class="icon-container" onclick="openEditOrganizationModal(@organization.OrganizationId, '@encodedName', '@encodedEmail', '@organization.DateBegin?.ToString("yyyy-MM-dd")', '@organization.DateEnd?.ToString("yyyy-MM-dd")')">
                            <span><i class="fas fa-pen-to-square"></i></span>
                            <span class="icon-tooltip">Редактировать</span>
                        </div>
                        <div class="icon-container" onclick="delete_organization(@organization.OrganizationId)">
                            <span><i class="fas fa-trash"></i></span>
                            <span class="icon-tooltip">Удалить</span>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
