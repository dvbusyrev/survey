@{
    ViewData["Title"] = "Добавление организации";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/organization.css" asp-append-version="true" />
}

<div class="app-page app-page--narrow organization-form-page" id="default_content" data-page="organization-add">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Добавление новой организации",
            Description = "В форме ниже вы можете задать данные для новой организации."
        })
    <section class="app-page__section">
        @await Html.PartialAsync("~/Views/Organization/Partials/_AddOrganizationForm.cshtml")
    </section>
</div>

@section Scripts {
    <script src="~/js/features/organization/organization-page.js" asp-append-version="true"></script>
}
