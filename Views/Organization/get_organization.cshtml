@model MainProject.Services.Admin.OrganizationListPageViewModel

@{
    ViewData["Title"] = "Список организаций";
    ViewData["OrganizationSection"] = "list";
    var organizations = Model?.Organizations ?? Array.Empty<MainProject.Models.Organization>();
    var openAddOrganizationModal = Model?.OpenAddOrganizationModal ?? false;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/organization.css" asp-append-version="true" />
}

<div class="app-page organization-page" id="default_content" data-page="organization-list">
    @await Html.PartialAsync("~/Views/Organization/Partials/_OrganizationSubnav.cshtml")
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Список организаций",
            Description = "Ниже представлена таблица с существующими организациями."
        })
    <section class="app-page__section">
        @await Html.PartialAsync("~/Views/Organization/Partials/_OrganizationToolbar.cshtml")
    </section>
    <section class="app-page__section app-page__section--flush">
        @await Html.PartialAsync("~/Views/Organization/Partials/_OrganizationTable.cshtml", organizations)
    </section>
</div>

@await Html.PartialAsync("~/Views/Organization/Partials/_AddOrganizationModal.cshtml")
@await Html.PartialAsync("~/Views/Organization/Partials/_EditOrganizationModal.cshtml")

@section Scripts {
    <script src="~/js/pages/organization.js" asp-append-version="true"></script>
    <script>
    (function(){
        if (@(openAddOrganizationModal.ToString().ToLowerInvariant())) {
            setTimeout(function(){
                if (typeof window.openAddOrganizationModal === 'function') {
                    window.openAddOrganizationModal();
                }
            }, 0);
        }
    })();
    </script>
}
