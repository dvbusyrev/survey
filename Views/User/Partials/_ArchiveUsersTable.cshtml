@model List<main_project.Models.User>
@using main_project.Infrastructure.Security

<table id="data_table" class="users-table users-table--archive">
    <thead>
        <tr class="table_tr">
            <th class="table-th--start">ФИО пользователя</th>
            <th>Имя пользователя</th>
            <th>Организация</th>
            <th>Роль</th>
            <th>Дата начала</th>
            <th class="table-th--end">Дата окончания</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="6" class="table-empty-cell">Результаты не найдены!</td>
            </tr>
        }
        else
        {
            foreach (var user in Model)
            {
                <tr>
                    <td>@(string.IsNullOrWhiteSpace(user.full_name) ? "Не указано" : user.full_name)</td>
                    <td>@user.name_user</td>
                    <td>@(string.IsNullOrWhiteSpace(user.organization_name) ? "Не указано" : user.organization_name)</td>
                    <td>@AppRoles.GetDisplayName(user.name_role)</td>
                    <td>@(user.date_begin?.ToString("dd.MM.yyyy") ?? "")</td>
                    <td>@(user.date_end?.ToString("dd.MM.yyyy") ?? "")</td>
                </tr>
            }
        }
    </tbody>
</table>
