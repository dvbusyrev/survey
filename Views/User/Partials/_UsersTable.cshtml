@model List<main_project.Models.User>

<table id="data_table" class="users-table">
    <thead>
        <tr class="table_tr">
            <th style="border-radius: 16px 0 0 0">ФИО</th>
            <th>Логин</th>
            <th>Организация</th>
            <th>Роль</th>
            <th>Почта</th>
            <th>Дата начала</th>
            <th>Дата конца</th>
            <th style="border-radius: 0 16px 0 0">Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr>
                <td colspan="8" style="color:red">Результаты не найдены!</td>
            </tr>
        }
        else
        {
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.full_name</td>
                    <td>@user.name_user</td>
                    <td>@user.name_omsu</td>
                    <td>
                        @if (user.name_role == "user")
                        {
                            @:Пользователь
                        }
                        else
                        {
                            @:Админ
                        }
                    </td>
                    <td>@user.email</td>
                    <td>@user.date_begin?.ToString("dd.MM.yyyy")</td>
                    <td>@user.date_end?.ToString("dd.MM.yyyy")</td>
                    <td class="action-icons">
                        <div class="icon-container" onclick="openEditUserModal(@user.id_user, '@Html.Raw(user.full_name)', '@Html.Raw(user.name_user)', '@Html.Raw(user.email)', @user.id_omsu, '@Html.Raw(user.name_role)', '@user.date_begin?.ToString("yyyy-MM-dd")', '@user.date_end?.ToString("yyyy-MM-dd")')">
                            <span>✏️</span><span class="icon-tooltip">Редактировать</span>
                        </div>
                        <div class="icon-container" onclick="promptDeleteUser(@user.id_user, '@Html.Raw(user.full_name)')">
                            <span>🗑️</span><span class="icon-tooltip">Удалить</span>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
