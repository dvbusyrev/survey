<div id="addUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Добавление пользователя</h2>
        </div>
        <span class="modal-close" onclick="closeUserModal('addUserModal')">&times;</span>
        <div class="modal-body">
            <div id="message"></div>
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="fullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="username" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="password" id="password" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="email_input" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="organization" class="form-control" required>
                    <option value="">Выберите организацию</option>
                    @if (ViewBag.Organizations != null)
                    {
                        foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="role_bd" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="Админ">Администратор</option>
                </select>
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button type="button" onclick="submitFormAdd()" class="modal_btn modal_btn-primary">Сохранить</button>
            <button type="button" onclick="closeUserModal('addUserModal')" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>
