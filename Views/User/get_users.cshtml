@model List<main_project.Models.User>

<div class="content users-page" id="default_content">
    <div class="note">
        <h2>Список пользователей</h2>
        <p>Ниже представлена таблица с существующими пользователями</p>
    </div>

    <div class="users-page-toolbar" style="display:flex; justify-content: space-between; align-items:center; gap:12px; margin-bottom:12px;">
    <button type="button" class="modal_btn modal_btn-primary" onclick="openAddUserModal()">Добавить пользователя</button>
    <p class="back-button" id="check_archive_omsu" onclick="archive_list_users()" style="cursor: pointer; margin:0;">
        Посмотреть архив ->
    </p>
</div>

    <table id="data_table">
        <thead>
            <tr class='table_tr'>
                <th style="border-radius: 16px 0 0 0">ФИО</th>
                <th>Логин</th>
                <th>Организация</th>
                <th>Роль</th>
                 <th>Почта</th>
                <th>Дата начала</th>
                <th>Дата конца</th>
                <th style="border-radius: 0 16px 0 0">Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any()) {
                <tr>
                    <td colspan="8" style='color:red'>Результаты не найдены!</td>
                </tr>
            } else {
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.full_name</td>
                        <td>@user.name_user</td>
                        <td>@user.name_omsu</td>
                        <td>                            @if (user.name_role == "user")
                            {
                                @:Пользователь
                            }
                            else
                            {
                                @:Админ
                            }</td>
                        <td>@user.email</td>
                        <td>@user.date_begin?.ToString("dd.MM.yyyy")</td>
                        <td>@user.date_end?.ToString("dd.MM.yyyy")</td>
                        <td class="action-icons">
                            <div class="icon-container" onclick="openEditUserModal(@user.id_user, '@Html.Raw(user.full_name)', '@Html.Raw(user.name_user)', '@Html.Raw(user.email)', @user.id_omsu, '@Html.Raw(user.name_role)', '@user.date_begin?.ToString("yyyy-MM-dd")', '@user.date_end?.ToString("yyyy-MM-dd")')">
                                <span>✏️</span><span class="icon-tooltip">Редактировать</span>
                            </div>
                            <div class="icon-container" onclick="deleteUser(@user.id_user, '@Html.Raw(user.full_name)')">
                                <span>🗑️</span><span class="icon-tooltip">Удалить</span>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>



<!-- Модальное окно добавления -->
<div id="addUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Добавление пользователя</h2>
        </div>
        <span class="modal-close" onclick="document.getElementById('addUserModal').style.display='none'">&times;</span>
        <div class="modal-body">
            <div id="message"></div>
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="fullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="username" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="password" id="password" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="email_input" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="organization" class="form-control" required>
                    <option value="">Выберите организацию</option>
                    @if (ViewBag.Organizations != null)
                    {
                        foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="role_bd" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="Админ">Администратор</option>
                </select>
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button type="button" onclick="submitFormAdd()" class="modal_btn modal_btn-primary">Сохранить</button>
            <button type="button" onclick="document.getElementById('addUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

 <!-- Модальное окно редактирования -->
<div id="editUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Редактирование пользователя</h2>
        </div>
        <span class="modal-close" onclick="document.getElementById('editUserModal').style.display='none'">&times;</span>
        <div class="modal-body">
            <input type="hidden" id="editUserId">
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="editFullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="editUsername" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="password" id="editPassword" class="form-control" placeholder="Оставьте пустым, чтобы не изменять">
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="editEmail" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="editOrganization" class="form-control" required>
                    @if (ViewBag.Organizations != null)
                    {
                        foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="editRole" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="Админ">Администратор</option>
                </select>
            </div>
            <div class="form-group">
                <label>Дата начала:</label>
                <input type="date" id="editDateBegin" class="form-control">
            </div>
            <div class="form-group">
                <label>Дата окончания:</label>
                <input type="date" id="editDateEnd" class="form-control">
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button onclick="updateUser()" class="modal_btn modal_btn-primary">Сохранить</button>
            <button onclick="document.getElementById('editUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

    <!-- Модальное окно удаления -->
    <div id="deleteUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Удаление пользователя</h2>
                <span class="modal-close" onclick="document.getElementById('deleteUserModal').style.display='none'">&times;</span>
            </div>
            <div class="modal-body">
                <p>Вы действительно хотите удалить пользователя <span id="deleteUserName"></span>?</p>
                <input type="hidden" id="deleteUserId">
                @Html.AntiForgeryToken()
            </div>
            <div class="modal-footer">
                <button onclick="deleteUser()" class="modal_btn modal_btn-danger">Удалить</button>
                <button onclick="document.getElementById('deleteUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
            </div>
        </div>
    </div>
</div>

<script>
(function(){
    window.openAddUserModal = window.openAddUserModal || function(){
        var modal = document.getElementById('addUserModal');
        if (modal) modal.style.display = 'block';
    };

    var originalEdit = window.openEditUserModal;
    window.openEditUserModal = async function(id, fullName, username, email, orgId, role, dateBegin, dateEnd) {
        if (typeof originalEdit === 'function') {
            await originalEdit(id, fullName, username, email, orgId, role, dateBegin, dateEnd);
        } else {
            document.getElementById('editUserId').value = id || '';
            document.getElementById('editFullName').value = fullName || '';
            document.getElementById('editUsername').value = username || '';
            document.getElementById('editRole').value = role || 'user';
            document.getElementById('editDateBegin').value = (dateBegin || '').split('T')[0];
            document.getElementById('editDateEnd').value = (dateEnd || '').split('T')[0];
            document.getElementById('editOrganization').value = orgId || '';
            document.getElementById('editUserModal').style.display = 'block';
        }

        var emailEl = document.getElementById('editEmail');
        if (emailEl) emailEl.value = email || '';
    };

    if (!window.submitFormAdd) {
        window.submitFormAdd = async function() {
            const messageElement = document.getElementById('message');
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const formData = {
                username: document.getElementById('username')?.value || '',
                password: document.getElementById('password')?.value || '',
                fullName: document.getElementById('fullName')?.value || '',
                email: document.getElementById('email_input')?.value || '',
                organizationId: document.getElementById('organization')?.value || '0',
                role: document.getElementById('role_bd')?.value || 'user'
            };

            try {
                const response = await fetch('/add_user_bd', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        ...(tokenEl ? { 'RequestVerificationToken': tokenEl.value } : {})
                    },
                    body: JSON.stringify(formData)
                });
                const data = await response.json();
                if (messageElement) {
                    messageElement.textContent = data.message || '';
                    messageElement.className = data.success ? 'success-message' : 'error-message';
                }
                if (data.success) {
                    document.getElementById('addUserModal').style.display = 'none';
                    if (typeof handleTabClick === 'function') handleTabClick('get_users');
                    else location.reload();
                }
            } catch (error) {
                if (messageElement) {
                    messageElement.textContent = 'Ошибка соединения';
                    messageElement.className = 'error-message';
                }
            }
        };
    }

    var originalUpdate = window.updateUser;
    window.updateUser = async function() {
        const emailEl = document.getElementById('editEmail');
        const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        const idEl = document.getElementById('editUserId');

        if (!emailEl || !idEl) {
            if (typeof originalUpdate === 'function') return originalUpdate();
            return;
        }

        const formData = {
            username: document.getElementById('editUsername')?.value || '',
            password: document.getElementById('editPassword')?.value || 'keep_original',
            fullName: document.getElementById('editFullName')?.value || '',
            email: emailEl.value || '',
            organizationId: document.getElementById('editOrganization')?.value || '0',
            role: document.getElementById('editRole')?.value || 'user',
            dateBegin: document.getElementById('editDateBegin')?.value || '',
            dateEnd: document.getElementById('editDateEnd')?.value || ''
        };

        try {
            const response = await fetch(`/update_user_bd/${idEl.value}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...(tokenEl ? { 'RequestVerificationToken': tokenEl.value } : {})
                },
                body: JSON.stringify(formData)
            });
            const result = await response.json();
            if (!response.ok || !result.success) throw new Error(result.message || 'Ошибка обновления');
            document.getElementById('editUserModal').style.display = 'none';
            if (typeof handleTabClick === 'function') handleTabClick('get_users');
            else location.reload();
        } catch (e) {
            alert(e.message || 'Ошибка обновления');
        }
    };

    var openAdd = @((ViewBag.OpenAddUserModal ?? false).ToString().ToLower());
    if (openAdd) {
        setTimeout(function(){ window.openAddUserModal(); }, 0);
    }
})();
</script>