@model List<main_project.Models.User>
@using main_project.Infrastructure.Security

@await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
<link rel="stylesheet" href="~/css/pages/users.css" asp-append-version="true" />

<div class="content users-page" id="default_content">
    <div class="note">
        <h2>Список пользователей</h2>
        <p>Ниже представлена таблица с существующими пользователями</p>
    </div>

    <div class="users-page-toolbar">
        <button type="button" class="modal_btn modal_btn-primary" onclick="openAddUserModal()">Добавить пользователя</button>
        <p class="back-button back-button--compact users-page__archive-link" id="check_archive_organization" onclick="archive_list_users()">
            Посмотреть архив ->
        </p>
    </div>

    <div class="table-responsive">
        <table id="data_table" class="users-table">
            <thead>
                <tr class='table_tr'>
                    <th class="table-th--start">ФИО</th>
                    <th>Логин</th>
                    <th>Организация</th>
                    <th>Роль</th>
                    <th>Почта</th>
                    <th>Дата начала</th>
                    <th>Дата конца</th>
                    <th class="table-th--end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any()) {
                    <tr>
                        <td colspan="8" class="table-empty-cell">Результаты не найдены!</td>
                    </tr>
                } else {
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.full_name</td>
                            <td>@user.name_user</td>
                            <td>@user.organization_name</td>
                            <td>@AppRoles.GetDisplayName(user.name_role)</td>
                            <td>@user.email</td>
                            <td>@user.date_begin?.ToString("dd.MM.yyyy")</td>
                            <td>@user.date_end?.ToString("dd.MM.yyyy")</td>
                            <td class="action-icons">
                                <div class="icon-container" onclick="openEditUserModal(@user.id_user, '@Html.Raw(user.full_name)', '@Html.Raw(user.name_user)', '@Html.Raw(user.email)', @user.organization_id, '@Html.Raw(AppRoles.Normalize(user.name_role))', '@user.date_begin?.ToString("yyyy-MM-dd")', '@user.date_end?.ToString("yyyy-MM-dd")')">
                                    <span><i class="fas fa-pen-to-square"></i></span><span class="icon-tooltip">Редактировать</span>
                                </div>
                                <div class="icon-container" onclick="deleteUser(@user.id_user, '@Html.Raw(user.full_name)')">
                                    <span><i class="fas fa-trash"></i></span><span class="icon-tooltip">Удалить</span>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>


<!-- Модальное окно добавления -->
<div id="addUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Добавление пользователя</h2>
        </div>
        <span class="modal-close" onclick="window.hideSiteModal ? window.hideSiteModal('addUserModal') : document.getElementById('addUserModal').style.display='none'"><i class="fas fa-xmark"></i></span>
        <div class="modal-body">
            <div id="message"></div>
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="fullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="username" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="text" id="password" class="form-control is-password-masked" data-password-field="true" data-password-visible="false" autocomplete="new-password" inputmode="text" lang="ru" autocapitalize="none" spellcheck="false" required>
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="email_input" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="organization" class="form-control" required>
                    <option value="">Выберите организацию</option>
                    @if (ViewBag.Organizations != null)
                    {
                        foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="role_bd" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="admin">Администратор</option>
                </select>
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button type="button" onclick="submitFormAdd()" class="modal_btn modal_btn-primary">Сохранить</button>
            <button type="button" onclick="window.hideSiteModal ? window.hideSiteModal('addUserModal') : document.getElementById('addUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

 <!-- Модальное окно редактирования -->
<div id="editUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Редактирование пользователя</h2>
        </div>
        <span class="modal-close" onclick="window.hideSiteModal ? window.hideSiteModal('editUserModal') : document.getElementById('editUserModal').style.display='none'"><i class="fas fa-xmark"></i></span>
        <div class="modal-body">
            <input type="hidden" id="editUserId">
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="editFullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="editUsername" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="text" id="editPassword" class="form-control is-password-masked" data-password-field="true" data-password-visible="false" autocomplete="new-password" inputmode="text" lang="ru" autocapitalize="none" spellcheck="false" placeholder="Оставьте пустым">
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="editEmail" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="editOrganization" class="form-control" required>
                    @if (ViewBag.Organizations != null)
                    {
                        foreach (var org in ViewBag.Organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="editRole" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="admin">Администратор</option>
                </select>
            </div>
            <div class="form-group">
                <label>Дата начала:</label>
                <input type="date" id="editDateBegin" class="form-control">
            </div>
            <div class="form-group">
                <label>Дата окончания:</label>
                <input type="date" id="editDateEnd" class="form-control">
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button onclick="updateUser()" class="modal_btn modal_btn-primary">Сохранить</button>
            <button onclick="window.hideSiteModal ? window.hideSiteModal('editUserModal') : document.getElementById('editUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

    <!-- Модальное окно удаления -->
    <div id="deleteUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Удаление пользователя</h2>
                <span class="modal-close" onclick="window.hideSiteModal ? window.hideSiteModal('deleteUserModal') : document.getElementById('deleteUserModal').style.display='none'"><i class="fas fa-xmark"></i></span>
            </div>
            <div class="modal-body">
                <p>Вы действительно хотите удалить пользователя <span id="deleteUserName"></span>?</p>
                <input type="hidden" id="deleteUserId">
                @Html.AntiForgeryToken()
            </div>
            <div class="modal-footer">
                <button onclick="deleteUser()" class="modal_btn modal_btn-danger">Удалить</button>
                <button onclick="window.hideSiteModal ? window.hideSiteModal('deleteUserModal') : document.getElementById('deleteUserModal').style.display='none'" class="modal_btn modal_btn-secondary">Отмена</button>
            </div>
        </div>
    </div>
</div>


<script>
(function(){
    if (@((ViewBag.OpenAddUserModal ?? false).ToString().ToLower())) {
        setTimeout(function(){
            if (typeof window.openAddUserModal === 'function') {
                window.openAddUserModal();
            } else {
                var modal = document.getElementById('addUserModal');
                if (modal) {
                    if (window.showSiteModal) {
                        window.showSiteModal(modal);
                    } else {
                        modal.style.display = 'flex';
                    }
                }
            }
        }, 0);
    }
})();
</script>
