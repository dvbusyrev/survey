@model MainProject.Services.Admin.UserListPageViewModel
@using MainProject.Infrastructure.Security

@{
    ViewData["Title"] = "Список пользователей";
    var users = Model?.Users ?? Array.Empty<MainProject.Models.User>();
    var organizations = Model?.Organizations ?? Array.Empty<MainProject.Services.Admin.SelectionOption>();
    var openAddUserModal = Model?.OpenAddUserModal ?? false;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/users.css" asp-append-version="true" />
}

<div class="app-page users-page" id="default_content" data-page="users-list">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Список пользователей",
            Description = "Ниже представлена таблица с существующими пользователями."
        })

    <section class="app-page__section">
        <div class="users-page-toolbar app-page__toolbar">
            <button type="button" class="modal_btn modal_btn-primary" data-click-call="openAddUserModal">Добавить пользователя</button>
            <button type="button"
                    class="back-button back-button--compact users-page__archive-link"
                    id="check_archive_organization"
                    data-tab-target="archive_list_users"
                    data-fallback-url="/archive_list_users">
                Посмотреть архив ->
            </button>
        </div>

        <div class="table-responsive">
            <table id="data_table" class="users-table">
                <thead>
                    <tr class='table_tr'>
                        <th class="table-th--start">ФИО</th>
                        <th>Логин</th>
                        <th>Организация</th>
                        <th>Роль</th>
                        <th>Почта</th>
                        <th>Дата начала</th>
                        <th>Дата конца</th>
                        <th class="table-th--end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!users.Any()) {
                        <tr>
                            <td colspan="8" class="table-empty-cell">Результаты не найдены!</td>
                        </tr>
                    } else {
                        @foreach (var user in users)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.NameUser</td>
                                <td>@user.OrganizationName</td>
                                <td>@AppRoles.GetDisplayName(user.NameRole)</td>
                                <td>@user.Email</td>
                                <td>@user.DateBegin?.ToString("dd.MM.yyyy")</td>
                                <td>@user.DateEnd?.ToString("dd.MM.yyyy")</td>
                                <td class="action-icons">
                                    <div class="icon-container"
                                         data-user-id="@user.IdUser"
                                         data-user-full-name="@(user.FullName ?? string.Empty)"
                                         data-user-name="@(user.NameUser ?? string.Empty)"
                                         data-user-email="@(user.Email ?? string.Empty)"
                                         data-user-organization-id="@user.OrganizationId"
                                         data-user-role="@AppRoles.Normalize(user.NameRole)"
                                         data-user-date-begin="@(user.DateBegin?.ToString("yyyy-MM-dd") ?? string.Empty)"
                                         data-user-date-end="@(user.DateEnd?.ToString("yyyy-MM-dd") ?? string.Empty)"
                                         data-click-call="openEditUserModalFromTrigger"
                                         data-click-pass-element="true">
                                        <span><i class="fas fa-pen-to-square"></i></span><span class="icon-tooltip">Редактировать</span>
                                    </div>
                                    <div class="icon-container"
                                         data-user-id="@user.IdUser"
                                         data-user-full-name="@(user.FullName ?? string.Empty)"
                                         data-click-call="deleteUserFromTrigger"
                                         data-click-pass-element="true">
                                        <span><i class="fas fa-trash"></i></span><span class="icon-tooltip">Удалить</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>


<!-- Модальное окно добавления -->
<div id="addUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Добавление пользователя</h2>
        </div>
        <span class="modal-close" data-modal-close="addUserModal"><i class="fas fa-xmark"></i></span>
        <div class="modal-body">
            <div id="message"></div>
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="fullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="username" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="text" id="password" class="form-control is-password-masked" data-password-field="true" data-password-visible="false" autocomplete="new-password" inputmode="text" lang="ru" autocapitalize="none" spellcheck="false" required>
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="email_input" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="organization" class="form-control" required>
                    <option value="">Выберите организацию</option>
                    @foreach (var org in organizations)
                    {
                        <option value="@org.Id">@org.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="role" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="admin">Администратор</option>
                </select>
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button type="button" data-click-call="submitFormAdd" class="modal_btn modal_btn-primary">Сохранить</button>
            <button type="button" data-modal-close="addUserModal" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

 <!-- Модальное окно редактирования -->
<div id="editUserModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Редактирование пользователя</h2>
        </div>
        <span class="modal-close" data-modal-close="editUserModal"><i class="fas fa-xmark"></i></span>
        <div class="modal-body">
            <input type="hidden" id="editUserId">
            <div class="form-group">
                <label>ФИО:</label>
                <input type="text" id="editFullName" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Логин:</label>
                <input type="text" id="editUsername" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Пароль:</label>
                <input type="text" id="editPassword" class="form-control is-password-masked" data-password-field="true" data-password-visible="false" autocomplete="new-password" inputmode="text" lang="ru" autocapitalize="none" spellcheck="false" placeholder="Оставьте пустым">
            </div>
            <div class="form-group">
                <label>Email:</label>
                <input type="email" id="editEmail" class="form-control">
            </div>
            <div class="form-group">
                <label>Организация:</label>
                <select id="editOrganization" class="form-control" required>
                    @foreach (var org in organizations)
                    {
                        <option value="@org.Id">@org.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Роль:</label>
                <select id="editRole" class="form-control">
                    <option value="user">Пользователь</option>
                    <option value="admin">Администратор</option>
                </select>
            </div>
            <div class="form-group">
                <label>Дата начала:</label>
                <input type="date" id="editDateBegin" class="form-control">
            </div>
            <div class="form-group">
                <label>Дата окончания:</label>
                <input type="date" id="editDateEnd" class="form-control">
            </div>
            @Html.AntiForgeryToken()
        </div>
        <div class="modal-footer">
            <button data-click-call="updateUser" class="modal_btn modal_btn-primary">Сохранить</button>
            <button data-modal-close="editUserModal" class="modal_btn modal_btn-secondary">Отмена</button>
        </div>
    </div>
</div>

    <!-- Модальное окно удаления -->
    <div id="deleteUserModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Удаление пользователя</h2>
                <span class="modal-close" data-modal-close="deleteUserModal"><i class="fas fa-xmark"></i></span>
            </div>
            <div class="modal-body">
                <p>Вы действительно хотите удалить пользователя <span id="deleteUserName"></span>?</p>
                <input type="hidden" id="deleteUserId">
                @Html.AntiForgeryToken()
            </div>
            <div class="modal-footer">
                <button data-click-call="deleteUserFromModal" class="modal_btn modal_btn-danger">Удалить</button>
                <button data-modal-close="deleteUserModal" class="modal_btn modal_btn-secondary">Отмена</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @await Html.PartialAsync("~/Views/Shared/_AdminPageScripts.cshtml")
    <script>
    (function(){
        if (@(openAddUserModal.ToString().ToLower())) {
            setTimeout(function(){
                if (typeof window.openAddUserModal === 'function') {
                    window.openAddUserModal();
                } else {
                    var modal = document.getElementById('addUserModal');
                    if (modal) {
                        if (window.showSiteModal) {
                            window.showSiteModal(modal);
                        } else {
                            modal.style.display = 'flex';
                        }
                    }
                }
            }, 0);
        }
    })();
    </script>
}
