@model main_project.Models.User
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - main_project</title>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        .form-group {
            margin-bottom: 15px;
            display: flex; 
            align-items: center;
        }

        .form-group label {
            flex: 0 0 200px;
            margin-right: 10px;
            text-align: right;
        }

        .form-control {
            flex: 1; 
            padding: 10px;
            border: 1px solid #ced4da;
            border-radius: 5px;
            transition: border-color 0.3s;
        }

        .form-control:focus {
            border-color: #007bff;
            outline: none;
        }

        .button-container {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }

    </style>
</head>
<body>

    <div class="content" id="default_content">
        <div class="note">
            <h2>Редактирование пользователя</h2>
            <p>В форме ниже вы можете изменить данные пользователя</p>
        </div>
        
        <div class="form-group">
            <label for="username">Логин</label>
            <input type="text" class="form-control" value="@Model?.name_user" id="username" placeholder="Введите логин" required />
        </div>
        <div class="form-group">
            <label for="password">Пароль</label>
            <input type="password" class="form-control" value="" id="password" placeholder="Оставьте пустым, чтобы не менять пароль" />
        </div>
        <div class="form-group">
            <label for="confirm_password">Повторите пароль</label>
            <input type="password" class="form-control" value="" id="confirm_password" placeholder="Повторите новый пароль" />
        </div>
        <div class="form-group">
            <label for="fullName">Фамилия, Имя, Отчество</label>
            <input type="text" class="form-control" value="@Model?.full_name" id="fullName" placeholder="Введите ФИО" required />
        </div>
        <div class="form-group">
            <label for="email">Email сотрудника</label>
            <input type="email" class="form-control" value="@Model?.email" id="email" placeholder="Введите email" required />
        </div>
        <div class="form-group">
            <label for="organization">Название организации</label>
            <select class="form-control" id="organization">
                <option value="@Model?.id_omsu" selected>@Model?.name_omsu</option>
            </select>
        </div>
        <div class="form-group">
            <label for="role">Роль</label>
            <select class="form-control" id="role_bd">
                <option value="user" selected="@(Model?.name_role == "user")">Пользователь</option>
                <option value="Админ" selected="@(Model?.name_role == "Админ")">Админ</option>
            </select>
        </div>
        <div class="button-container">
            <button type="submit" class="btn" onClick="update_user_bd(@Model?.id_user)">Обновить пользователя</button>
        </div>
    </div>
</body>