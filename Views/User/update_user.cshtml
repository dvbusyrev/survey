@model main_project.Models.User
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - main_project</title>
    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        .form-group {
            margin-bottom: 15px;
            display: flex; 
            align-items: center;
        }

        .form-group label {
            flex: 0 0 200px;
            margin-right: 10px;
            text-align: right;
        }

        .form-control {
            flex: 1; 
            padding: 10px;
            border: 1px solid #ced4da;
            border-radius: 5px;
            transition: border-color 0.3s;
        }

        .form-control:focus {
            border-color: #007bff;
            outline: none;
        }

        .button-container {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }

        .password-field-wrap {
            position: relative;
            flex: 1;
            display: flex;
        }

        .password-field-wrap .form-control {
            width: 100%;
            padding-right: 42px;
        }

        .password-toggle-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 24px;
            height: 24px;
            border: none;
            background: transparent;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #6b7280;
            cursor: pointer;
            opacity: 0.85;
            transition: color 0.2s ease, opacity 0.2s ease, transform 0.2s ease;
        }

        .password-toggle-btn:hover {
            color: #667eea;
            opacity: 1;
            transform: translateY(-50%) scale(1.05);
        }

        .password-toggle-btn:focus {
            outline: none;
        }

        .password-toggle-btn svg {
            width: 20px;
            height: 20px;
            stroke: currentColor;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    </style>
</head>
<body>

    <div class="content" id="default_content">
        <div class="note">
            <h2>Редактирование пользователя</h2>
            <p>В форме ниже вы можете изменить данные пользователя</p>
        </div>
        
        <div class="form-group">
            <label for="username">Логин</label>
            <input type="text" class="form-control" value="@Model?.name_user" id="username" placeholder="Введите логин" required />
        </div>
        <div class="form-group">
            <label for="password">Пароль</label>
            <div class="password-field-wrap">
                <input type="password" class="form-control" value="@Model?.hash_password" id="password" placeholder="Введите пароль" required />
                <button type="button" class="password-toggle-btn" data-target="password" aria-label="Показать пароль" title="Показать пароль"></button>
            </div>
        </div>
        <div class="form-group">
            <label for="confirm_password">Повторите пароль</label>
            <div class="password-field-wrap">
                <input type="password" class="form-control" value="@Model?.hash_password" id="confirm_password" placeholder="Введите пароль еще раз" required />
                <button type="button" class="password-toggle-btn" data-target="confirm_password" aria-label="Показать пароль" title="Показать пароль"></button>
            </div>
        </div>
        <div class="form-group">
            <label for="fullName">Фамилия, Имя, Отчество</label>
            <input type="text" class="form-control" value="@Model?.full_name" id="fullName" placeholder="Введите ФИО" required />
        </div>
        <div class="form-group">
            <label for="email">Email сотрудника</label>
            <input type="email" class="form-control" value="@Model?.email" id="email" placeholder="Введите email" required />
        </div>
        <div class="form-group">
            <label for="organization">Название организации</label>
            <select class="form-control" id="organization">
                <option value="@Model?.id_omsu" selected>@Model?.name_omsu</option>
            </select>
        </div>
        <div class="form-group">
            <label for="role">Роль</label>
            <select class="form-control" id="role_bd">
                <option value="user" selected="@(Model?.name_role == "user")">Пользователь</option>
                <option value="Админ" selected="@(Model?.name_role == "Админ")">Админ</option>
            </select>
        </div>
        <div class="button-container">
            <button type="submit" class="btn" onClick="update_user_bd(@Model?.id_user)">Обновить пользователя</button>
        </div>
    </div>

    <script>
        function createEyeSvg(isVisible) {
            return isVisible
                ? `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 3l18 18"></path><path d="M10.6 10.7a3 3 0 0 0 4 4"></path><path d="M9.9 5.2A11 11 0 0 1 12 5c6.5 0 10 7 10 7a17.3 17.3 0 0 1-4.1 4.8"></path><path d="M6.6 6.7A17.7 17.7 0 0 0 2 12s3.5 7 10 7a10.8 10.8 0 0 0 5.2-1.3"></path></svg>`
                : `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.password-toggle-btn').forEach(function(btn) {
                const input = document.getElementById(btn.dataset.target);
                if (!input) return;

                btn.innerHTML = createEyeSvg(false);
                btn.addEventListener('click', function() {
                    const show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    btn.innerHTML = createEyeSvg(show);
                    btn.setAttribute('aria-label', show ? 'Скрыть пароль' : 'Показать пароль');
                    btn.setAttribute('title', show ? 'Скрыть пароль' : 'Показать пароль');
                });
            });
        });
    </script>

</body>