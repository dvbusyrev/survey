@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Авторизация</title>
    <link rel="icon" type="image/svg+xml" href="/images/icon.svg" />
    <link rel="stylesheet" href="/css/local-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        .content {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
background: 
    linear-gradient(135deg, #b7c4f8 0%, #c8b0dd 100%),
    radial-gradient(circle at 10% 20%, rgba(255,255,255,0.8) 0%, transparent 25%);
            padding: 20px;
        }

        .inner-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 3rem;
            border-radius: 16px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1),
                        0 16px 48px rgba(0, 0, 0, 0.1),
                        0 0 0 1px rgba(255, 255, 255, 0.1);
            opacity: 0;
            transform: translateY(10px);
            animation: 0.6s ease-out forwards form-fade-in;
        }

        .form-title {
            color: #1a1a1a;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 2rem;
            text-align: center;
            line-height: 1.2;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .welcome-text {
            font-size: 1.75rem;
            color: #667eea;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            color: #4a5568;
            font-size: 0.875rem;
            font-weight: 500;
            transition: all 0.2s ease;
            padding-left: 0;
        }

        .form-group:focus-within .form-label {
            transform: scale(1.1);
            font-weight: 600;
            color: #667eea;
            padding-left: 1px;
            transform-origin: left;
        }

        .input-container {
            position: relative;
            display: flex;
            align-items: stretch;
            gap: 0;
            transition: all 0.2s ease;
        }

        .icon-container {
            width: 46px;
            background: rgba(102, 126, 234, 0.1);
            border-radius: 8px 0 0 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #667eea;
            border: 2px solid #e2e8f0;
            transition: all 0.2s ease;
            transform-origin: left center;
        }

        .icon-container i {
            font-size: 1.4rem;
            opacity: 0.9;
            transition: all 0.2s ease;
        }

        .form-input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 2px solid #e2e8f0;
            border-radius: 0 8px 8px 0;
            font-size: 1rem;
            transition: all 0.2s ease;
            background: white;
            margin-left: -2px;
        }

        .form-input:focus {
            outline: none;
            border-color: #667eea;
            width: calc(100% - 6px);
            margin-left: 4px;
        }

        .input-container:focus-within .icon-container {
            transform: scale(1.1);
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.25);
        }

        .input-container:focus-within .icon-container i {
            opacity: 1;
            transform: scale(1.15);
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .checkbox-input {
            appearance: none;
            width: 1.25rem;
            height: 1.25rem;
            border: 2px solid #e2e8f0;
            border-radius: 4px;
            margin-right: 0.75rem;
            cursor: pointer;
            position: relative;
            transition: all 0.2s ease;
        }

        .checkbox-input:checked {
            background-color: #667eea;
            border-color: #667eea;
        }

        .checkbox-input:checked::after {
            content: '✓';
            position: absolute;
            color: white;
            font-size: 0.875rem;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }

        .checkbox-label {
            color: #4a5568;
            font-size: 0.875rem;
            cursor: pointer;
        }

        .submit-button {
            width: 100%;
             background: linear-gradient(145deg, #9a7dff 0%, #6a5acd 100%);
    border: none;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 
        0 4px 6px rgba(0, 0, 0, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
        }

        .submit-button:hover {
            background: linear-gradient(145deg, #8a6dff 0%, #5a4acd 100%);
    box-shadow: 
        0 6px 8px rgba(0, 0, 0, 0.15),
        inset 0 1px 0 rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
        }

        @@keyframes buttonShine {
            0% {
                transform: translateX(-100%);
            }
            20% {
                transform: translateX(100%);
            }
            100% {
                transform: translateX(100%);
            }
        }


        .submit-button:hover::before {
            animation: hoverShine 1.2s ease-in-out infinite;
        }

        @@keyframes form-fade-in {
            0% {
                opacity: 0;
                transform: translateY(10px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
            max-width: 400px;
            width: 90%;
            text-align: center;
            animation: modal-fade-in 0.3s ease-out;
        }

        .modal-title {
            color: #ff4c5b;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .modal-message {
            color: #4a5568;
            margin-bottom: 1.5rem;
            line-height: 1.5;
        }

        .modal-button {
            background: #667eea;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .modal-button:hover {
            background: #5a67d8;
            transform: translateY(-1px);
        }

        @@keyframes modal-fade-in {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
    <div id="root"></div>

    @if (Env.IsDevelopment())
    {
        <script type="module" src="http://localhost:5173/@@vite/client"></script>
        <script type="module" src="http://localhost:5173/src/entries/auth.jsx"></script>
    }
    else
    {
        <script type="module" src="/dist/auth.js"></script>
    }
</body>
</html>
