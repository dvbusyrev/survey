@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Авторизация</title>

  <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/local-icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/auth-page.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div id="global-antiforgery-token" hidden aria-hidden="true">
        @Html.AntiForgeryToken()
    </div>
    <div id="root"></div>
    <template id="auth-login-template">
        <div class="content">
            <div class="inner-container">
                <form id="loginForm">
                    <h1 class="form-title">
                        <span class="welcome-text">АНКЕТИРОВАНИЕ</span>
                    </h1>

                    <div class="form-group">
                        <label class="form-label" for="username">Имя пользователя</label>
                        <div class="input-container">
                            <div class="icon-container"><i class="fas fa-user"></i></div>
                            <input type="text" class="form-input" id="username" name="username" required placeholder="Введите имя пользователя" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="password">Пароль</label>
                        <div class="input-container has-toggle">
                            <div class="icon-container"><i class="fas fa-lock"></i></div>
                            <input
                                type="text"
                                class="form-input is-password-masked"
                                id="password"
                                name="password"
                                required
                                autoComplete="current-password"
                                autoCapitalize="none"
                                autoCorrect="off"
                                spellcheck="false"
                                inputmode="text"
                                lang="ru"
                                data-password-field="true"
                                placeholder="Введите пароль" />
                            <button type="button" class="password-toggle-btn" aria-label="Показать пароль" title="Показать пароль"></button>
                        </div>
                    </div>

                    <button type="submit" class="submit-button">Войти</button>
                </form>
            </div>
        </div>
    </template>
    <template id="auth-modal-template">
        <div class="modal-overlay u-hidden">
            <div class="modal-content">
                <h2 class="modal-title"></h2>
                <p class="modal-message"></p>
                <button class="modal-button" type="button">Закрыть</button>
            </div>
        </div>
    </template>
    <template id="auth-eye-open-template">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12z"></path>
            <circle cx="12" cy="12" r="3"></circle>
        </svg>
    </template>
    <template id="auth-eye-closed-template">
        <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 3l18 18"></path>
            <path d="M10.6 10.7a3 3 0 0 0 4 4"></path>
            <path d="M9.9 5.2A11 11 0 0 1 12 5c6.5 0 10 7 10 7a17.3 17.3 0 0 1-4.1 4.8"></path>
            <path d="M6.6 6.7A17.7 17.7 0 0 0 2 12s3.5 7 10 7a10.8 10.8 0 0 0 5.2-1.3"></path>
        </svg>
    </template>

    <script src="~/js/core/antiforgery.js" asp-append-version="true"></script>
    <script src="~/js/dist/auth-page.js" asp-append-version="true"></script>
</body>
</html>
