                        const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));

                        card.querySelector('.time-left').textContent = `${days} д ${hours} ч ${minutes} м`;
                    } else {
                        card.querySelector('.time-left').textContent = 'продлена';
                    }
                });
            }
        }
        // Обновление времени каждую минуту
        setInterval(updateTimeLeft, 1);

function pagination_surv() {
    const surveyGrid = document.getElementById("surveyGrid");
    const surveys = surveyGrid ? surveyGrid.querySelectorAll(".card") : [];
    const itemsPerPage = 5; // Количество анкет на одной странице
    let currentPage = 1;

    // Функция для отображения текущей страницы
    function showPage(page) {
        if (!surveyGrid || surveys.length === 0) {
            console.error("Не найден элемент #surveyGrid или анкеты отсутствуют.");
            return;
        }

        const start = (page - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        surveys.forEach((survey, index) => {
            if (index >= start && index < end) {
                survey.style.display = "block";
            } else {
                survey.style.display = "none";
            }
        });

        updatePaginationInfo();
    }

    // Функция для обновления информации о странице
    function updatePaginationInfo() {
        const totalPages = Math.ceil(surveys.length / itemsPerPage);
        const pageInfo = document.getElementById("pageInfo");
        if (pageInfo) {
            pageInfo.textContent = `Страница ${currentPage} из ${totalPages}`;
        } else {
            console.error("Не найден элемент #pageInfo.");
        }
    }

    // Функция для перехода на предыдущую страницу
    window.goToPrevPage = function () {
        if (currentPage > 1) {
            currentPage--;
            showPage(currentPage);
        }
    };

    // Функция для перехода на следующую страницу
    window.goToNextPage = function () {
        const totalPages = Math.ceil(surveys.length / itemsPerPage);
        if (currentPage < totalPages) {
            currentPage++;
            showPage(currentPage);
        }
    };

    // Инициализация пагинации
    showPage(currentPage);
}

