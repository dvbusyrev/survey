// ФУНКЦИЯ ОБРАБОТКИ ЗАПОЛНЕНИЯ АНКЕТЫ(ОБРАБОТКА ОТВЕТОВ)
function insert_answer(omsu_id) {
    const answers = [];

    // Получаем все контейнеры вопросов
    const questionContainers = document.querySelectorAll('.question-container');
    const surveyId = document.querySelector('.content').getAttribute('id');

    // Перебираем контейнеры вопросов и собираем ответы
    questionContainers.forEach(container => {
            if (container.querySelector(".error-message-zapoln")){container.querySelector(".error-message-zapoln").remove();}
        const questionText = container.querySelector('h3').innerHTML;
        const questionId = container.id.replace("quest_", ""); // Получаем ID вопроса
        const ratingButtons = container.querySelectorAll('.btn_crit');

        let selectedRating = null;

        // Находим выбранную оценку
        ratingButtons.forEach(button => {
            if (button.classList.contains('active')) {
                selectedRating = parseInt(button.innerText); // Получаем текст кнопки как оценку
            }
        });

        // Если оценка не выбрана, добавляем ошибку в контейнер вопроса
        if (selectedRating == null) 
        {
                const errorElement = document.createElement('div');
                errorElement.className = 'error-message-zapoln';
                errorElement.textContent = "Вы пропустили вопрос!";
                container.appendChild(errorElement);
        return;
        }

        // Получаем комментарий, если он существует
        const commentContainer = container.querySelector('.comment-container textarea');
        let comment = commentContainer ? commentContainer.value.trim() : "";

        // Если оценка меньше 5, требуем комментарий
        if (selectedRating < 5 && !comment) 
        {
                const errorElement = document.createElement('div');
                errorElement.className = 'error-message-zapoln';
                errorElement.textContent = "Для оценки ниже 5 баллов требуется комментарий.";
                container.appendChild(errorElement);
                        return;
        }

        // Если оценка выбрана, добавляем в массив ответов
        answers.push({
            question_id: questionId,
            question_text: questionText,
            rating: selectedRating,
            comment: comment || ""
        });
    });

    // Проверяем, есть ли ответы для отправки
if (answers.length == 0) {
    const errorMessageElement = document.getElementById('error-message');
    document.getElementById('error-text').innerHTML = "Нет ответов для отправки!";

    // Показываем сообщение об ошибке
    errorMessageElement.style.display = "flex"; // Используем flex для центрирования
    errorMessageElement.style.visibility = "visible";

    return;
}

    if (answers.length != questionContainers.length) {
    const errorMessageElement = document.getElementById('error-message');
    document.getElementById('error-text').innerHTML = "На каждый вопрос должен быть ответ!";

    // Показываем сообщение об ошибке
    errorMessageElement.style.display = "flex"; // Используем flex для центрирования
    errorMessageElement.style.visibility = "visible";
    return;
}

    // Создаем объект с данными для отправки
    const historyAnswerData = {
        id_omsu: omsu_id,
        csp: signature,
        id_survey: surveyId,
        completion_date: new Date().toISOString(),  // Текущая дата в ISO формате
        answers: JSON.stringify(answers)  // Преобразуем массив ответов в строку JSON
    };

    const currentBody = document.querySelector('main');

    const xhr = new XMLHttpRequest();
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                window.scrollTo({
    top: 0,
    behavior: 'auto' // Мгновенная прокрутка
});
                currentBody.innerHTML = xhr.responseText;
                document.querySelector('.content').style.width = "78%";
                document.querySelector('.content').style.marginLeft = "19%";
            } else {
                console.error("Ошибочка: " + xhr.status);
            }
        }
    };

    xhr.onerror = function() {
        console.error("Проблемы с интернетом");
    };

    xhr.open("POST", "/api/insert_answer", true);
    xhr.setRequestHeader("Content-Type", "application/json");
    
    xhr.send(JSON.stringify(historyAnswerData));
}

// Функция для очистки ошибок при изменении оценки или комментария
function clearErrors(container) {
    const errorElements = container.querySelectorAll('.error-message-zapoln');
    errorElements.forEach(error => error.remove());
}

function check_ocenka(ocenka, question) {
    // Получаем элемент вопроса
    var questionDiv = document.getElementById('quest_' + question);

    // Сбрасываем стиль всех кнопок в этом вопросе
    var buttons = questionDiv.querySelectorAll('.btn_crit');
    buttons.forEach(function (btn) {
        btn.style.backgroundColor = "transparent";
        btn.style.color = "#004e88";
        btn.className = 'btn_crit';
    });

    // Получаем кнопку с выбранной оценкой
    var button = questionDiv.querySelector('#btn' + ocenka);

    // Изменяем стиль выбранной кнопки
    button.style.backgroundColor = "#004e88";
    button.style.color = "white";
    button.style.fontWeight = "bold";
    button.className = 'btn_crit active';

    // Очищаем ошибки в контейнере вопроса
    clearErrors(questionDiv);

    // Проверяем, если оценка меньше 5
    if (ocenka < 5) {
        // Проверяем, есть ли уже комментарий для этой оценки
        var activeComments = questionDiv.getElementsByClassName('comment-container');

        if (activeComments.length == 0) {
            // Добавляем новый комментарий
            var commentContainer = document.createElement('div');
            commentContainer.className = 'comment-container';
            commentContainer.innerHTML = `
                <textarea placeholder="Ваш комментарий..." rows="3" style="width: 96%; margin-left: 20px; margin-bottom: 20px; margin-right: 20px;"></textarea>
            `;
            questionDiv.appendChild(commentContainer);
        }
    } else {
        // Удаляем комментарий, если оценка 5
        var activeComments = questionDiv.getElementsByClassName('comment-container');
        if (activeComments.length > 0) {
            activeComments[0].remove();
        }
    }
}


