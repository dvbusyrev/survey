       function CSP(id, id_omsu) {
        cadesplugin.then(async function() {
            try {
                // Создаем объект хранилища
                const oStore = await cadesplugin.CreateObjectAsync("CAdESCOM.Store");
                
                // Открываем хранилище с правильными параметрами
                await oStore.Open(
                    CADESCOM_CONTAINER_STORE, // тип хранилища
                    "My", // имя хранилища
                    CAPICOM_STORE_OPEN_READ_ONLY // режим открытия
                );

                // Получаем сертификаты
                const certificates = await oStore.Certificates;
                const validCertificates = await certificates.Find(
                    CAPICOM_CERTIFICATE_FIND_TIME_VALID
                );

                if (validCertificates.Count === 0) {
                    throw new Error("Не найдено действительных сертификатов");
                }

                const certificate = await validCertificates.Item(1);
                const signer = await cadesplugin.CreateObjectAsync("CAdESCOM.CPSigner");
                await signer.propset_Certificate(certificate);

                const dataToSign = "Test Data"; 
                
                const signedData = await cadesplugin.CreateObjectAsync("CAdESCOM.CadesSignedData");
                await signedData.propset_Content(dataToSign);

                signature = await signedData.SignCades(signer, CADESCOM_CADES_BES);

                await oStore.Close();
                CSP_get(id, id_omsu, signature);


            } catch (error) {
                console.error("Ошибка:", error);
                alert("Ошибка при создании подписи: " + error.message);
            }
        }).catch(function(error) {
            console.error("Ошибка инициализации плагина:", error);
            alert("Ошибка инициализации плагина: " + error);
        });

}

