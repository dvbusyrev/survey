function CSP_get(id, idOmsu, signature) {

    // Отправляем POST-запрос с использованием fetch
    fetch(`/csp/${id}/${idOmsu}`, {
        method: "POST",
        headers: {
            "Content-Type": "application/json" // Указываем тип контента JSON
        },
        body: JSON.stringify(signature) // Передаем подпись в теле запроса
    })
    .then(response => {
        if (response.ok) {
            document.getElementById("block_btn_not_csp").style.display = "none";
            document.getElementById("block_btn_csp").style.display = "block";
        } else {
            console.error("Ошибка при подписании анкеты: " + response.status);
        }
    })
    .catch(error => {
        console.error("Проблемы с интернетом: " + error);
    });
}

