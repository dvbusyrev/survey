function populateNewOrganizations(type) {
    let optionsHtml = "";
    const organizationSelect = document.getElementById("organizationSelect");

    if (type !== 'filter') {
        // Добавляем пункт "Не выбрано" и "Все организации"
        optionsHtml += `<option value="none" id="none">Не выбрано</option>`;
        optionsHtml += `<option value="all">Все организации</option>`;
    } else {
        optionsHtml += `<option value="none" id="none">Не выбрано</option>`;
    }

    const xhr = new XMLHttpRequest();

    xhr.onreadystatechange = function () {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                const organizations = JSON.parse(xhr.responseText);
                const organizationSelect = document.getElementById("organizationSelect");

                if (organizationSelect) {
                    if (organizations && organizations.ids && organizations.names) {
                        for (let i = 0; i < organizations.ids.length; i++) {
                            optionsHtml += `<option value="${organizations.ids[i]}">${organizations.names[i]}</option>`;
                        }
                        organizationSelect.innerHTML = optionsHtml;
                    } else {
                        console.error("Некорректный формат данных от сервера.");
                        organizationSelect.innerHTML = '<option value="">Ошибка получения данных</option>';
                    }
                } else {
                    console.error("Элемент с id 'organizationSelect' не найден в DOM.");
                }
            } else {
                console.error("Ошибка при получении данных: " + xhr.status);
                const organizationSelect = document.getElementById("organizationSelect");
                if (organizationSelect) {
                    organizationSelect.innerHTML = '<option value="">Ошибка получения данных</option>';
                } else {
                    console.error("Элемент с id 'organizationSelect' не найден в DOM.");
                }
            }
        }
    };

    xhr.onerror = function () {
        console.error("Проблемы с интернетом");
        const organizationSelect = document.getElementById("organizationSelect");
        if (organizationSelect) {
            organizationSelect.innerHTML = '<option value="">Ошибка сети</option>';
        } else {
            console.error("Элемент с id 'organizationSelect' не найден в DOM.");
        }
    };

    xhr.open("GET", "/get_omsu/data", true);
    xhr.send();
}


