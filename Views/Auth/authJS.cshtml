// ФИЛЬТРАЦИЯ АНКЕТ ПО МЕСЯЦУ
function applyMonthFilter() {
    var hidden = false;
    const monthFilter = document.getElementById("monthFilter").value.toLowerCase();
    const table = document.getElementById("data_table");
    const tr = table.getElementsByTagName("tr");

        if (document.querySelector('#none_search')){document.querySelector('#none_search').remove()}

    for (let i = 1; i < tr.length; i++) { // Start from 1 to skip header row
        const td = tr[i].getElementsByTagName("td")[1]; // Get the second column (month)
        
        if (td) {
            const txtValue = td.textContent || td.innerText;
            if (txtValue == monthFilter || monthFilter == "") {

                tr[i].style.display = ""; // Show row
                hidden = true;
            } else {
                tr[i].style.display = "none"; // Hide row
            }
        }
    }

    if (hidden == false){table.querySelector("tbody").innerHTML+="<p id='none_search' style='color:red'>Результаты не найдены!<p>"}

    closeModal(); // Close the modal after applying the filter
}

