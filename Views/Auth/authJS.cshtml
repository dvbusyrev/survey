function update_survey_bd(id) {

    var surveyTitle = document.getElementById('surveyTitle').value;
    var surveyDescription = document.getElementById('surveyDescription').value;
    var startDate = document.getElementById('startDate').value;
    var endDate = document.getElementById('endDate').value;

    if (!surveyTitle || !surveyDescription || !startDate || !endDate) {
        alert("Все поля должны быть заполнены!");
        return;
    }

    // Проверка даты завершения
    var startDateObj = new Date(startDate);
    var endDateObj = new Date(endDate);
    if (endDateObj <= startDateObj) {
        alert("Дата завершения не может быть раньше или равна дате начала.");
        return;
    }

    // Массив для хранения идентификаторов выбранных ОМСУ
    var selectedOmsuIds = [];
    var organizationSelects = document.getElementsByTagName("select");
    for (var i = 0; i < organizationSelects.length; i++) {
        if (organizationSelects[i].id === "organizationSelect" && organizationSelects[i].selectedIndex !== -1) {
            selectedOmsuIds.push(organizationSelects[i].options[organizationSelects[i].selectedIndex].value);
        }
    }

    // Получаем значения критериев
    var criteriyInputs = document.getElementsByClassName("criteriy");
    var criteriyValues = [];
    for (var i = 0; i < criteriyInputs.length; i++) {
        var criteriyValue = criteriyInputs[i].value.trim();
        if (!criteriyValue) {
            alert("Все критерии должны быть заполнены!");
            return;
        }
        criteriyValues.push(criteriyValue);
    }

    var data_survey = [];
    data_survey.push(document.getElementById('surveyTitle').value);
    data_survey.push(document.getElementById('surveyDescription').value);
    data_survey.push(document.getElementById('startDate').value);
    data_survey.push(document.getElementById('endDate').value);

    var selectedOmsuIds = [];
    var organizationSelects = document.getElementsByTagName("select");

    for (var i = 0; i < organizationSelects.length; i++) {
        if (organizationSelects[i].id === "organizationSelect" && organizationSelects[i].selectedIndex !== -1) {
            selectedOmsuIds.push(organizationSelects[i].options[organizationSelects[i].selectedIndex].value);
        }
    }

    var omsuIdsString = selectedOmsuIds.join(',');
    data_survey.push(omsuIdsString);

    var criteriyInputs = document.getElementsByClassName("criteriy");
    for (var i = 0; i < criteriyInputs.length; i++) {
        data_survey.push(criteriyInputs[i].value);
    }

    

    const xhr = new XMLHttpRequest();
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                alert("Анкета успешно отредактирована");
                open_vkladka('surveys');
            } else {
                console.error("Ошибка: " + xhr.status);
                alert("Ошибка при обновлении анкеты");
            }
        }
    };
    
    xhr.onerror = function() {
        console.error("Проблемы с интернетом");
        alert("Проблемы с интернетом");
    };
    
    xhr.open("POST", `/update_survey_bd/${id}`, true);
    xhr.setRequestHeader("Content-Type", "application/json;charset=UTF-8");
    xhr.send(JSON.stringify(data_survey));
}

