function getRandomColor(opacity) {
    // Задаем базовый цвет (синий)
    const baseBlue = 150;

    // Генерируем случайные отклонения от базового синего
    const r = Math.floor(Math.random() * baseBlue);  // От 0 до baseBlue
    const g = Math.floor(Math.random() * baseBlue);  // От 0 до baseBlue
    const b = baseBlue + Math.floor(Math.random() * (255 - baseBlue)); // От baseBlue до 255

    return `rgba(${r}, ${g}, ${b}, ${opacity})`;
}

