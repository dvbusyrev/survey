function applyOMSUFilter() {
    var hidden = false;
    const organizationSelect = document.getElementById("organizationSelect");
    const selectedOption = organizationSelect.options[organizationSelect.selectedIndex];

    const omsuFilter = selectedOption.innerHTML.toLowerCase();
    const table = document.getElementById("data_table");
    const tr = table.getElementsByTagName("tr");

    if (document.querySelector('#none_search')) {
        document.querySelector('#none_search').remove();
    }

    for (let i = 1; i < tr.length; i++) {
        const tds = tr[i].getElementsByTagName("td");
        let rowVisible = false;

        for (let j = 0; j < tds.length; j++) {
            const txtValue = tds[j].textContent.toLowerCase() || tds[j].innerText.toLowerCase();
            if (txtValue.includes(omsuFilter) || omsuFilter === "") {
                rowVisible = true;
                break;
            }
        }

        if (rowVisible) {
            tr[i].style.display = "";
            hidden = true;
        } else {
            tr[i].style.display = "none";
        }
    }

    if (!hidden) {
        table.querySelector("tbody").innerHTML += "<p id='none_search' style='color:red'>Результаты не найдены!</p>";
    }

    closeModal();
}

// Функция для сортировки таблицы
function sortTable(columnIndex) {
    const table = document.getElementById("data_table");
    const rows = table.rows;
    
    const monthOrder = ["январь", "февраль", "март", "апрель", "май", "июнь", "июль", "август", "сентябрь", "октябрь", "ноябрь", "декабрь"];
    
    let direction;

    // Определяем текущее направление сортировки
    if (table.getAttribute('data-sort-direction') === 'desc') {
        direction = 'asc';
    } else {
        direction = 'desc';
    }
    
    table.setAttribute('data-sort-direction', direction); // Обновляем направление сортировки


    // Устанавливаем текущий значок в зависимости от направления
    const currentSortIcon = document.getElementById(`sortIcon${columnIndex}`);
    
    if (direction === 'asc') {
        currentSortIcon.textContent = "🔽"; // Устанавливаем вниз
    } else {
        currentSortIcon.textContent = "🔼"; // Устанавливаем вверх
    }

   // Преобразуем строки таблицы в массив для сортировки
   const rowsArray = [];
   for (let i = 1; i < rows.length; i++) { // Пропускаем заголовок
       rowsArray.push(rows[i]);
   }

   // Сортировка строк
   rowsArray.sort((a, b) => {
       const cellA = a.getElementsByTagName("td")[columnIndex].innerHTML.toLowerCase();
       const cellB = b.getElementsByTagName("td")[columnIndex].innerHTML.toLowerCase();

       if (columnIndex === 1) { // Сортировка по месяцу
           const monthIndexA = monthOrder.indexOf(cellA);
           const monthIndexB = monthOrder.indexOf(cellB);
           return direction === 'asc' ? monthIndexA - monthIndexB : monthIndexB - monthIndexA;
       } else { // Сортировка по другим столбцам
           return direction === 'asc' ? cellA.localeCompare(cellB) : cellB.localeCompare(cellA);
       }
   });

   // Очистка тела таблицы и добавление отсортированных строк
   const tbody = table.querySelector("tbody");
   tbody.innerHTML = "";
   for (let i = 0; i < rowsArray.length; i++) {
       tbody.appendChild(rowsArray[i]);
   }
}



// Инициализация переменных
let currentPage = 1;
const itemsPerPage = 20; // Количество записей на странице
let filteredData = [];
var totalPages = 0;

// Функция для отображения предыдущей страницы
function prevPage() {
    if (currentPage > 1) {
        currentPage--;
        showPage(currentPage);
    }
}

// Функция для отображения следующей страницы
function nextPage() {

    if (currentPage < totalPages) {
        currentPage++;
        showPage(currentPage);
    }
}

// Функция для отображения определенной страницы
function showPage(page) {
    const tableBody = document.getElementById("data_table");
    
   
    // Получаем все строки таблицы
    if (tableBody){
    let rows;
    if (filteredData.length > 0) {
        rows = filteredData; // Используем отфильтрованные данные
    } else {
        rows = Array.from(tableBody.querySelectorAll("tr")); // Получаем все строки, включая заголовок
    }
    

    const totalRows = rows.length; // Общее количество строк
    totalPages = Math.ceil(totalRows / itemsPerPage); // Общее количество страниц

    // Проверка на допустимость текущей страницы
    if (page > totalPages || page <= 0) {
        return; // Если страница вне диапазона, ничего не делаем
    }

    const startIndex = (page - 1) * itemsPerPage; // Начальный индекс
    const endIndex = startIndex + itemsPerPage; // Конечный индекс

    // Скрываем или показываем строки в зависимости от текущей страницы
    for (let i = 0; i < totalRows; i++) {
        if (i >= startIndex && i < endIndex) {
            rows[i].style.display = ""; // Показываем строку
        } else {
            rows[i].style.display = "none"; // Скрываем строку
        }
    }

    // Обновляем информацию о текущей странице
    document.getElementById("pageInfo").textContent = `Страница ${page} из ${totalPages}`;

    // Управляем видимостью кнопок "Предыдущая" и "Следующая"
    document.getElementById("prevPageBtn").style.display = currentPage === 1 ? "none" : "inline-block";
    document.getElementById("nextPageBtn").style.display = currentPage === totalPages ? "none" : "inline-block";
}
}

