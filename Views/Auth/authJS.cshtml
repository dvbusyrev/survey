function get_active_omsu(type) {
    let optionsHtml = "";

    const xhr = new XMLHttpRequest();
    // Обработка изменения состояния запроса
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            if (xhr.status === 200) {
                const organizations = JSON.parse(xhr.responseText);

                // Предполагаем, что organizations имеет структуру { ids: [...], names: [...] }
                const ids = organizations.ids;
                const names = organizations.names;


                // Используем цикл for для добавления опций
                for (let i = 0; i < ids.length; i++) {
                    optionsHtml += `<option value="${ids[i]}">${names[i]}</option>`;
                }

                // Получаем все элементы с классом "organizationSelect"
                var organizationSelectElements = document.getElementsByClassName("organizationSelect");

                // Проходим по каждому элементу и обновляем его innerHTML
                for (var i = 0; i < organizationSelectElements.length; i++) {
                    organizationSelectElements[i].innerHTML = optionsHtml;
                }
            } else {
                console.error("Ошибка при получении данных: " + xhr.status);
            }
        }
    };

    // Обработка ошибок сети
    xhr.onerror = function() {
        console.error("Проблемы с интернетом");
    };

    // Отправка GET-запроса на сервер
    xhr.open("GET", "/get_omsu/data", true);
    xhr.send();
}

