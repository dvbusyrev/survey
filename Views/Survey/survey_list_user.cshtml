@model Survey
@using System.Security.Claims
@{
    ViewData["Title"] = "Активные анкеты";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string searchTerm = ViewBag.SearchTerm ?? "";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var nameOmsu = User.FindFirst("omsu_name")?.Value ?? "";
    var nameUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var displayName = !string.IsNullOrWhiteSpace(nameOmsu) && !string.IsNullOrWhiteSpace(nameUser)
        ? $"{nameOmsu}: {nameUser}"
        : (!string.IsNullOrWhiteSpace(nameUser) ? nameUser : userRole);
    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var userId = int.TryParse(userIdClaim, out var parsedUserId) ? parsedUserId : 0;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    int userOmsuId = ViewBag.UserOmsuId ?? 0;
    var accessibleSurveys = ViewBag.AccessibleSurveys as List<Survey> ?? new List<Survey>();
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

  <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/site2.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/local-icons.css" asp-append-version="true" />
</head>
<body>
    @if (!isAuthenticated)
    {
        <div class="access-denied" style="display: block;">
            <h2>Доступ запрещён</h2>
            <p>У вас нет прав для просмотра этой страницы.</p>
            <br/>
            <a href="/" class="btn">Вернуться на страницу авторизации</a>
        </div>
    }
    else
    {
        <div id="root"></div>


        <script src="~/js/react.development.js"></script>
        <script src="~/js/react-dom.development.js"></script>
        <script src="~/js/babel.min.js"></script>
        <script src="~/js/components/Header.js"></script>
        <script src="~/js/components/Navigation.js"></script>
        <script src="~/js/components/Footer.js"></script>



        <script type="text/babel" src="~/js/pages/survey-user-flow.jsx" asp-append-version="true"></script>

        <script type="text/babel" src="~/js/pages/survey-user-list.jsx" asp-append-version="true"></script>

        <script type="text/babel" src="~/js/pages/survey-user-list.jsx" asp-append-version="true"></script>

        <script type="text/babel">
window.renderSurveyUserList({
    userId: @userId,
    userRole: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(userRole)),
    userOmsuId: @userOmsuId,
    initialSurveys: @Html.Raw(Json.Serialize(accessibleSurveys)),
    initialPage: @currentPage,
    initialTotalPages: @totalPages,
    initialSearchTerm: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(searchTerm)),
    displayName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayName))
});
        </script>
    }

    <style>

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9fafb;
            color: var(--text-main);
            line-height: 1.5;
        }

        .page-container {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .admin-container {
            display: flex;
            flex: 1;
        }

        #content_admin {
            flex: 1;
            padding: 2rem;
            background-color: white;
        }

        /* Стили для заполнения анкеты */
        .survey-fill-container,
        .check-answers-container {
            padding: 2rem;
        }

        .note {
            margin-bottom: 2rem;
        }

        .note h2 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            color: var(--text-main);
        }

        .note p {
            color: var(--text-secondary);
            font-size: 1.05rem;
        }

        .question-container {
            margin-bottom: 2rem;
            padding: 1.5rem;
            background-color: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
        }

        .question-container h3 {
            margin-bottom: 1rem;
            font-size: 1.25rem;
        }

        .rating-buttons {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .btn_crit {
            width: 3rem;
            height: 3rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            background-color: var(--primary-light);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            border: none;
        }

        .comment-container {
            margin-top: 1rem;
        }

        .comment-container textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            resize: vertical;
            min-height: 100px;
        }

        .submit-container {
            margin-top: 2rem;
            text-align: center;
        }

        .submit-button {
            padding: 0.75rem 1.5rem;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .submit-button:hover {
            background-color: var(--primary-dark);
            box-shadow: var(--shadow-md);
        }

        .submit-button:disabled {
            background-color: var(--text-light);
            cursor: not-allowed;
        }

        /* Сообщение об успешном заполнении */
        .success-message {
            text-align: center;
            padding: 3rem;
            animation: fadeIn 0.6s ease-out;
        }

        .success-message svg {
            color: var(--success);
            margin-bottom: 1.5rem;
        }

        .success-message h2 {
            color: var(--success-dark);
            margin-bottom: 1rem;
        }

        .success-message p {
            color: var(--text-secondary);
        }

        /* Стили для просмотра ответов */
        .answer-container {
            margin-bottom: 2rem;
            padding: 1.5rem;
            background-color: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
        }

        .answer-info {
            margin-top: 1rem;
        }

        .rating {
            font-weight: 600;
            color: var(--primary-dark);
            display: block;
            margin-bottom: 0.5rem;
        }

        .comment {
            margin-top: 1rem;
        }

        .comment-text {
            padding: 0.75rem;
            background-color: var(--secondary);
            border-radius: var(--radius-sm);
        }

        .survey-add{display:none;}
        .survey-answers{display:none;}
        .survey-archive{display:none;}
        
        .statistic{display:none;}
        .organizations{display:none;}
        .other{display:none;}
        .users { display: none }
        .survey-answers-for-user { display: none }
        .survey-archive-for-user { display: none }
        .nav-link::after{display: none}


               /* Анимации */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @@keyframes slideIn {
            from { transform: translateX(20px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }


        /* Карточки анкет */
        .survey-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
            animation: fadeIn 0.6s ease-out;
        }

        .survey-card {
            background: white;
            border-radius: var(--radius-lg);
            padding: 1.75rem;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .survey-card:hover {
            transform: translateY(-5px) scale(1.01);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary-light);
            z-index: 5;
        }

        .survey-card h3 {
            margin-top: 0;
            color: var(--text-main);
            font-size: 1.35rem;
            font-weight: 600;
        }

        .survey-card:hover h3 {
            color: var(--primary-dark);
        }

        .survey-card .description {
            color: var(--text-secondary);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 1.5rem;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .survey-card .date-info {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            animation: slideIn 0.4s ease-out;
        }

        .survey-card .date-info svg {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
            color: var(--text-light);
            transition: var(--transition);
        }

        .survey-card:hover .date-info svg {
            color: var(--primary);
        }

        .survey-card .footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: auto;
            padding-top: 1.25rem;
            border-top: 1px dashed var(--border);
        }

        .survey-card .dates {
            font-size: 0.85rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .survey-card .dates svg {
            width: 1rem;
            height: 1rem;
            flex-shrink: 0;
            color: var(--text-light);
            transition: var(--transition);
        }

        .survey-card:hover .dates svg {
            color: var(--primary);
        }

        .survey-card .status {
            font-size: 0.8rem;
            font-weight: 700;
            padding: 0.5rem 1.2rem;
            border-radius: 9999px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: var(--transition);
            margin-left: auto;
            margin-right: 0;
        }

        .status.active {
            background-color: var(--primary-extra-light);
            color: var(--primary-dark);
            box-shadow: 0 2px 4px rgba(99, 102, 241, 0.1);
        }

        .status.archived {
            background-color: #f0fdf4;
            color: #166534;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.1);
        }

        .survey-card:hover .status.active {
            background-color: var(--primary-dark);
            color: white;
        }

        .survey-card:hover .status.archived {
            background-color: var(--success-dark);
            color: white;
        }

        .time-left {
            font-weight: 700;
            color: var(--warning);
            transition: var(--transition);
        }

        .survey-card:hover .time-left {
            color: var(--primary-dark);
        }

    .search-container {
        display: flex;
        gap: 12px;
        margin-bottom: 1.5rem;
        align-items: center;
        flex-wrap: wrap;
    }


    .search-box {
        width: 220px; /* Уменьшенная ширина */
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        font-size: 0.9rem;
        transition: var(--transition);
        height: 36px; /* Фиксированная высота */
    }

    .search-box:focus {
        outline: none;
        border-color: var(--primary-light);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

.filter-date {
    padding: 6px 12px;
    background-color: var(--primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    font-size: 14px;
    width: auto;
}

.filter-date:hover {
    background-color: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
}

    /* Пагинация */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
    }

    .pagination button {
        padding: 0.5rem 1rem;
        background-color: white;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: var(--transition);
    }

    .pagination button:hover:not(:disabled) {
        background-color: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .pagination button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

        .pagination span {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Загрузка */
        .loading {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            color: var(--text-secondary);
            animation: fadeIn 0.5s ease-out;
        }

        .loading-spinner {
            width: 3rem;
            height: 3rem;
            border: 3px solid var(--primary-extra-light);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 1.5rem;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Ошибка */
        .error-message {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--danger);
            background-color: rgba(239, 68, 68, 0.1);
            padding: 1.25rem;
            border-radius: var(--radius-md);
            margin-bottom: 2rem;
            border-left: 4px solid var(--danger);
            animation: slideIn 0.5s ease-out;
        }

.csp-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    padding: 20px;
}

.csp-modal-content {
    background: white;
    border-radius: 8px;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    overflow: hidden;
    animation: fadeIn 0.3s ease-out;
}

.csp-modal h3 {
    margin: 0;
    padding: 20px;
    font-size: 1.25rem;
    color: #333;
    border-bottom: 1px solid #eee;
}

.csp-modal-body {
    padding: 20px;
    color: #666;
    line-height: 1.5;
}

.csp-modal-footer {
    padding: 15px 20px;
    border-top: 1px solid #eee;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

/* Кнопки */
.csp-btn {
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
}

.csp-btn-primary {
    background-color: #3182ce;
    color: white;
}

.csp-btn-primary:hover {
    background-color: #2c5282;
}

.csp-btn-secondary {
    background-color: #e2e8f0;
    color: #4a5568;
}

.csp-btn-secondary:hover {
    background-color: #cbd5e0;
}

/* Центральные уведомления */
.csp-notification {
    position: fixed;
    top: 50%;
    left: 50%;
    padding: 16px 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    max-width: 80%;
    text-align: center;
}

.csp-notification.success {
    background-color: #48bb78;
    color: white;
}

.csp-notification.error {
    background-color: #f56565;
    color: white;
}

.csp-notification-icon {
    margin-right: 12px;
    font-weight: bold;
    font-size: 1.2em;
}

/* Анимации */
@@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.fade-out {
    animation: fadeOut 0.3s ease-out forwards;
}

@@keyframes fadeOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(10px); }
}

/* Детали сертификата */
.cert-details {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 15px;
    font-size: 14px;
}

.cert-details p {
    margin: 5px 0;
}

        .podpis {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #4CAF50; /* Зеленый цвет для подписи */
    font-size: 14px;
    margin-top: 8px;
}

.podpis svg {
    color: #4CAF50;
}

        .error-message svg {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
        }

        /* Нет анкет */
        .no-surveys {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem;
            color: var(--text-secondary);
            animation: fadeIn 0.6s ease-out;
        }

        .no-surveys svg {
            width: 3rem;
            height: 3rem;
            margin-bottom: 1rem;
            color: var(--text-light);
            opacity: 0.5;
        }
        /* Справочная информация */
        .help-content {
            padding: 2rem;
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            margin-top: 1.5rem;
            animation: fadeIn 0.6s ease-out;
        }

        .help-content h2, 
        .help-content h3 {
            color: var(--primary-dark);
            margin-top: 1.5rem;
        }

        .help-content p {
            line-height: 1.6;
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .help-content ul, 
        .help-content ol {
            margin: 1rem 0;
            padding-left: 2rem;
        }

        .help-content li {
            margin-bottom: 0.5rem;
        }

        /* Стили для блока подписи */
.signature-info {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 14px;
}

.signature-icon-container {
    display: flex;
    align-items: center;
}

.signature-icon {
    width: 18px;
    height: 18px;
    color: #5c6bc0; /* Фиолетовый цвет иконки */
}

.signature-label {
    color: #555;
}

.signature-status {
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 4px;
}

.signature-status.signed {
    color: green; /* Зеленый цвет текста */
}

.signature-status.not-signed {
    color: red; /* Красный цвет текста */
}

        /* Адаптивность */
        @@media (max-width: 768px) {
            .survey-grid {
                grid-template-columns: 1fr;
            }


            .search-container {
                flex-direction: column;
            }

            .survey-fill-container,
            .check-answers-container {
                padding: 1rem;
            }

            .question-container {
                padding: 1rem;
            }

            .rating-buttons {
                flex-wrap: wrap;
            }


            .btn_crit {
                width: 2.5rem;
                height: 2.5rem;
                font-size: 0.9rem;
            }
        }

        @@media (max-width: 480px) {
            #content_admin {
                padding: 1rem;
            }

            .survey-card {
                padding: 1.25rem;
            }

            .pagination {
                flex-direction: column;
                gap: 0.5rem;
            }

            .pagination button {
                width: 100%;
            }
        }


        /* Стили для модального окна с сертификатами */
.csp-modal-content {
    width: 100%;
    max-width: 600px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
}

/* Контейнер для списка с прокруткой */
.cert-list-container {
    max-height: 60vh;
    overflow-y: auto;
    margin: 10px -10px;
    padding: 0 10px;
}

/* Кастомный скроллбар */
.cert-list-container::-webkit-scrollbar {
    width: 8px;
}

.cert-list-container::-webkit-scrollbar-track {
    background: #f5f5f5;
    border-radius: 4px;
}

.cert-list-container::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 4px;
}

.cert-list-container::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
}

/* Список сертификатов */
.cert-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 5px 0;
}

/* Элемент сертификата */
.cert-item {
    padding: 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    background-color: white;
}

.cert-item:hover {
    background-color: #f8fafc;
    border-color: #cbd5e1;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.cert-item:active {
    transform: translateY(0);
}

/* Детали сертификата */
.cert-subject {
    font-weight: 600;
    margin-bottom: 8px;
    color: #1e293b;
    font-size: 15px;
}

.cert-details {
    font-size: 13px;
    color: #64748b;
    line-height: 1.5;
}

.cert-details div {
    margin-bottom: 4px;
}

.cert-details strong {
    color: #475569;
}

.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}

.loading-content {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
}

/* Стили для блока фильтров */
.filters {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    align-items: center;
}

.filter-group {
    display: flex;
    align-items: center;
    gap: 8px;
}

.signed-filter {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-left: auto;
    }

