    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 5px 0;
}

/* Элемент сертификата */
.cert-item {
    padding: 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    background-color: white;
}

.cert-item:hover {
    background-color: #f8fafc;
    border-color: #cbd5e1;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.cert-item:active {
    transform: translateY(0);
}

/* Детали сертификата */
.cert-subject {
    font-weight: 600;
    margin-bottom: 8px;
    color: #1e293b;
    font-size: 15px;
}

.cert-details {
    font-size: 13px;
    color: #64748b;
    line-height: 1.5;
}

.cert-details div {
    margin-bottom: 4px;
}

.cert-details strong {
    color: #475569;
}

.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}

.loading-content {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
}

/* Стили для блока фильтров */
.filters {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    align-items: center;
}

.filter-group {
    display: flex;
    align-items: center;
    gap: 8px;
}

.signed-filter {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        margin-left: auto;
    }

    .signed-filter input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--primary);
        cursor: pointer;
    }

.filter-group label {
    font-size: 14px;
    color: #4a5568;
}

.filter-group input[type="text"],
.filter-group input[type="date"] {
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 14px;
}

.filter-group input[type="checkbox"] {
    width: 16px;
    height: 16px;
}

    .filter-button {
        width: auto;
        margin-left: 1rem;
         padding: 6px 12px;
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: var(--radius-md);
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        height: 36px; /* Фиксированная высота */
        white-space: nowrap;
    }
    .filter-button:hover {
        background-color: var(--primary-dark);
    }
    .date-filters input[type="date"] {
        padding: 6px 8px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        height: 36px; /* Фиксированная высота */
        transition: var(--transition);
    }

    .date-filters input[type="date"]:focus {
        border-color: var(--primary-light);
        outline: none;
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

.search-button {
    padding: 8px 16px;
    background-color: #48bb78;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
}

.search-button:hover {
    background-color: #38a169;
}

.loading-spinner {
    width: 3rem;
    height: 3rem;
    border: 3px solid #f3f3f3;
    border-top: 3px solid #3498db;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
}



    /* Анимации */
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .survey-grid {
            grid-template-columns: 1fr;
        }
        
        .search-container {
            flex-direction: column;
        }
        
    .date-filters {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .date-filters label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    /* Календарные иконки для полей дат */
    .date-filters input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(0.5);
        cursor: pointer;
        padding: 4px;
    }

    .date-filters input[type="date"]::-webkit-calendar-picker-indicator:hover {
        filter: invert(0.3);
    }
        
        #content_admin {
            padding: 1rem;
        }
    }

    @@media (max-width: 480px) {
        .survey-card {
            padding: 1rem;
        }
        
        .pagination {
            flex-direction: column;
        }
        
        .rating-buttons {
            flex-wrap: wrap;
        }
        
        .btn_crit {
            width: 2.25rem;
            height: 2.25rem;
            font-size: 0.9rem;
        }
    }
    #otchets{display:none}
     #email{display:none}
    </style>
</body>
</html>