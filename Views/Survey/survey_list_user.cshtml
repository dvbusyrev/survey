        height: 36px; /* Фиксированная высота */
        transition: var(--transition);
    }

    .date-filters input[type="date"]:focus {
        border-color: var(--primary-light);
        outline: none;
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
