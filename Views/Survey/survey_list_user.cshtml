@model main_project.Services.Surveys.UserSurveyListPageViewModel
@using System.Security.Claims
@using main_project.Infrastructure.Security
@{
    ViewData["Title"] = "Активные анкеты";
    int currentPage = Model.CurrentPage;
    int totalPages = Model.TotalPages;
    string searchTerm = Model.SearchTerm;
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var nameOrganization = User.FindFirst("organization_name")?.Value ?? "";
    var nameUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var displayName = !string.IsNullOrWhiteSpace(nameOrganization) && !string.IsNullOrWhiteSpace(nameUser)
        ? $"{nameOrganization}: {nameUser}"
        : (!string.IsNullOrWhiteSpace(nameUser) ? nameUser : AppRoles.GetDisplayName(userRole));
    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var userId = int.TryParse(userIdClaim, out var parsedUserId) ? parsedUserId : 0;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    int userOrganizationId = Model.UserOrganizationId;
    var accessibleSurveys = Model.AccessibleSurveys;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

  <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" asp-append-version="true" />

    @await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
    <link rel="stylesheet" href="~/css/pages/survey-user.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    @if (!isAuthenticated)
    {
        <div class="access-denied">
            <h2>Доступ запрещён</h2>
            <p>У вас нет прав для просмотра этой страницы.</p>
            <br/>
            <a href="/" class="btn">Вернуться на страницу авторизации</a>
        </div>
    }
    else
    {
        <div id="root"></div>


        <script src="~/js/react.development.js"></script>
        <script src="~/js/react-dom.development.js"></script>
        <script src="~/js/babel.min.js"></script>
        <script src="~/js/components/Header.js" asp-append-version="true"></script>
        <script src="~/js/components/Navigation.js" asp-append-version="true"></script>
        <script src="~/js/components/Footer.js" asp-append-version="true"></script>



        <script type="text/babel" src="~/js/pages/survey-user-flow.jsx" asp-append-version="true"></script>

        <script type="text/babel" src="~/js/pages/survey-user-list.jsx" asp-append-version="true"></script>

        <script type="text/babel">
window.renderSurveyUserList({
    userId: @userId,
    userRole: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(userRole)),
    userOrganizationId: @userOrganizationId,
    initialSurveys: @Html.Raw(Json.Serialize(accessibleSurveys)),
    initialPage: @currentPage,
    initialTotalPages: @totalPages,
    initialTotalCount: @Model.TotalCount,
    initialSearchTerm: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(searchTerm)),
    displayName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayName)),
    userName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(nameUser)),
    organizationName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(nameOrganization))
});
        </script>
    }

    
</body>
</html>
