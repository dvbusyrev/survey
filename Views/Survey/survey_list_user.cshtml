            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            color: var(--text-secondary);
            animation: fadeIn 0.5s ease-out;
        }

        .loading-spinner {
            width: 3rem;
            height: 3rem;
            border: 3px solid var(--primary-extra-light);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 1.5rem;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Ошибка */
        .error-message {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--danger);
            background-color: rgba(239, 68, 68, 0.1);
            padding: 1.25rem;
            border-radius: var(--radius-md);
            margin-bottom: 2rem;
            border-left: 4px solid var(--danger);
            animation: slideIn 0.5s ease-out;
        }

.csp-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    padding: 20px;
}

.csp-modal-content {
    background: white;
    border-radius: 8px;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    overflow: hidden;
    animation: fadeIn 0.3s ease-out;
}

.csp-modal h3 {
    margin: 0;
    padding: 20px;
    font-size: 1.25rem;
    color: #333;
    border-bottom: 1px solid #eee;
}

.csp-modal-body {
    padding: 20px;
    color: #666;
    line-height: 1.5;
}

.csp-modal-footer {
    padding: 15px 20px;
    border-top: 1px solid #eee;
    display: flex;
    justify-content: flex-end;
    gap: 10px;
}

/* Кнопки */
.csp-btn {
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
}

.csp-btn-primary {
    background-color: #3182ce;
    color: white;
}

.csp-btn-primary:hover {
    background-color: #2c5282;
}

.csp-btn-secondary {
    background-color: #e2e8f0;
    color: #4a5568;
}

.csp-btn-secondary:hover {
    background-color: #cbd5e0;
}

/* Центральные уведомления */
.csp-notification {
    position: fixed;
    top: 50%;
    left: 50%;
    padding: 16px 24px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    max-width: 80%;
    text-align: center;
}

.csp-notification.success {
    background-color: #48bb78;
    color: white;
}

.csp-notification.error {
    background-color: #f56565;
    color: white;
}

.csp-notification-icon {
    margin-right: 12px;
    font-weight: bold;
    font-size: 1.2em;
}

/* Анимации */
@@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.fade-out {
    animation: fadeOut 0.3s ease-out forwards;
}

@@keyframes fadeOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(10px); }
}

/* Детали сертификата */
.cert-details {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 15px;
    font-size: 14px;
}

.cert-details p {
    margin: 5px 0;
}

        .podpis {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #4CAF50; /* Зеленый цвет для подписи */
    font-size: 14px;
    margin-top: 8px;
}

.podpis svg {
    color: #4CAF50;
}

        .error-message svg {
            width: 1.25rem;
            height: 1.25rem;
            flex-shrink: 0;
        }

        /* Нет анкет */
        .no-surveys {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem;
            color: var(--text-secondary);
            animation: fadeIn 0.6s ease-out;
        }

        .no-surveys svg {
            width: 3rem;
            height: 3rem;
            margin-bottom: 1rem;
            color: var(--text-light);
            opacity: 0.5;
        }
        /* Справочная информация */
        .help-content {
            padding: 2rem;
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-md);
            margin-top: 1.5rem;
            animation: fadeIn 0.6s ease-out;
        }

        .help-content h2, 
        .help-content h3 {
            color: var(--primary-dark);
            margin-top: 1.5rem;
        }

        .help-content p {
            line-height: 1.6;
            margin-bottom: 1rem;
            color: var(--text-main);
        }

        .help-content ul, 
        .help-content ol {
            margin: 1rem 0;
            padding-left: 2rem;
        }

        .help-content li {
            margin-bottom: 0.5rem;
        }

        /* Стили для блока подписи */
.signature-info {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 14px;
}

.signature-icon-container {
    display: flex;
    align-items: center;
}

.signature-icon {
    width: 18px;
    height: 18px;
    color: #5c6bc0; /* Фиолетовый цвет иконки */
}

.signature-label {
    color: #555;
}

.signature-status {
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 4px;
}

.signature-status.signed {
    color: green; /* Зеленый цвет текста */
}

.signature-status.not-signed {
    color: red; /* Красный цвет текста */
}

        /* Адаптивность */
        @@media (max-width: 768px) {
            .survey-grid {
                grid-template-columns: 1fr;
            }


            .search-container {
                flex-direction: column;
            }

            .survey-fill-container,
            .check-answers-container {
                padding: 1rem;
            }

            .question-container {
                padding: 1rem;
            }

            .rating-buttons {
                flex-wrap: wrap;
            }


            .btn_crit {
                width: 2.5rem;
                height: 2.5rem;
                font-size: 0.9rem;
            }
        }

        @@media (max-width: 480px) {
            #content_admin {
                padding: 1rem;
            }

            .survey-card {
                padding: 1.25rem;
            }

            .pagination {
                flex-direction: column;
                gap: 0.5rem;
            }

            .pagination button {
                width: 100%;
            }
        }


        /* Стили для модального окна с сертификатами */
.csp-modal-content {
    width: 100%;
    max-width: 600px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
}

/* Контейнер для списка с прокруткой */
.cert-list-container {
    max-height: 60vh;
    overflow-y: auto;
    margin: 10px -10px;
    padding: 0 10px;
}

/* Кастомный скроллбар */
.cert-list-container::-webkit-scrollbar {
    width: 8px;
}

.cert-list-container::-webkit-scrollbar-track {
    background: #f5f5f5;
    border-radius: 4px;
}

.cert-list-container::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 4px;
}

.cert-list-container::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
}

/* Список сертификатов */
.cert-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 5px 0;
}

/* Элемент сертификата */
.cert-item {
    padding: 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    background-color: white;
}

.cert-item:hover {
    background-color: #f8fafc;
    border-color: #cbd5e1;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.cert-item:active {
    transform: translateY(0);
}

/* Детали сертификата */
.cert-subject {
    font-weight: 600;
    margin-bottom: 8px;
    color: #1e293b;
    font-size: 15px;
}

.cert-details {
    font-size: 13px;
    color: #64748b;
    line-height: 1.5;
}

.cert-details div {
    margin-bottom: 4px;
}

.cert-details strong {
    color: #475569;
}

.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}

.loading-content {
    background: white;
    padding: 2rem;
