        width: 16px;
        height: 16px;
        accent-color: var(--primary);
        cursor: pointer;
    }

.filter-group label {
    font-size: 14px;
    color: #4a5568;
}

.filter-group input[type="text"],
.filter-group input[type="date"] {
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-size: 14px;
}

.filter-group input[type="checkbox"] {
    width: 16px;
    height: 16px;
}

    .filter-button {
        width: auto;
        margin-left: 1rem;
         padding: 6px 12px;
        background-color: var(--primary);
        color: white;
        border: none;
        border-radius: var(--radius-md);
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: var(--transition);
        height: 36px; /* Фиксированная высота */
        white-space: nowrap;
    }
    .filter-button:hover {
        background-color: var(--primary-dark);
    }
    .date-filters input[type="date"] {
        padding: 6px 8px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        height: 36px; /* Фиксированная высота */
        transition: var(--transition);
    }

    .date-filters input[type="date"]:focus {
