        width: 16px;
        height: 16px;
        accent-color: var(--primary);
        cursor: pointer;
    }

.filter-group label {
    font-size: 14px;
    color: #4a5568;
}

.filter-group input[type="text"],
.filter-group input[type="date"] {
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
