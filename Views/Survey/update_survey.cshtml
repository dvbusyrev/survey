@model MainProject.Services.Surveys.SurveyEditPageViewModel
@{
    var selectedOrganizationNamesJson = System.Text.Json.JsonSerializer.Serialize(Model.SelectedOrganizationNames);
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Обновление анкеты</title>
    @await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
    <style>
        #conf_btn { background-color: #28a745; color: white; }
        #add_crit { background-color: #17a2b8; color: white; }
        .confirmed { background-color: rgba(40, 167, 69, 0.1); border-left: 4px solid #28a745; }
        .error-message { color: #dc3545; font-size: 12px; margin-top: 5px; display: none; }
    </style>
</head>
<body onload="surveyEditInit()">
 @Html.AntiForgeryToken()
    <div class="content" id="default_content">
        <div class="note">
            <h2>Обновление анкеты</h2>
            <p>Заполните форму ниже для обновления анкеты</p>
        </div>

        <div class="step">
            <h3>Шаг 1</h3>
            <div class="form-group">
                <label for="surveyTitle">Название:</label>
                <input type="text" class="form-control" id="surveyTitle" value="@Model.Survey.NameSurvey" required />
                <div class="error-message" id="titleError"></div>
            </div>
            <div class="form-group">
                <label for="surveyDescription">Описание:</label>
                <textarea class="form-control" id="surveyDescription">@Model.Survey.Description</textarea>
            </div>
            <div class="form-group">
                <label for="startDate">Дата начала:</label>
                <input type="date" class="form-control" id="startDate" value="@Model.Survey.DateOpen.ToString("yyyy-MM-dd")" required />
                <div class="error-message" id="startDateError"></div>
            </div>
            <div class="form-group">
                <label for="endDate">Дата окончания:</label>
                <input type="date" class="form-control" id="endDate" value="@Model.Survey.DateClose.ToString("yyyy-MM-dd")" required />
                <div class="error-message" id="endDateError"></div>
            </div>

            <div class="form-group">
                <label>Организации:</label>
                <button type="button" class="btn" onclick="surveyEditOpenOrganizationModal()">Выбрать ОМСУ</button>
                <input type="hidden" id="selectedOrganizationIds" value="@string.Join(",", Model.SelectedOrganizationIds)" />
                <div id="selectedOrganizationContainer" class="selected-organization" style="display: none;">
                    <div id="selectedOrganizationList"></div>
                </div>
                <div class="error-message" id="organizationError">Выберите хотя бы одну организацию</div>
            </div>
        </div>
        <br />

        <div class="step" id="two_step">
            <h3>Шаг 2</h3>
            <div id="cont_criteries">
                @foreach (var criterion in Model.Criteria)
                {
                    <div class="form-group cont_criteries">
                        <label>Критерий оценки</label>
                        <input type="text" class="form-control criteriy" value="@criterion" required />
                        <div class="error-message"></div>
                    </div>
                }
            </div>
        </div>

        <div class="criteria-buttons-container">
            <button type="button" class="criteria-btn" id="add_crit" onclick="surveyEditAddCriteria()">Добавить еще критерий</button>
            <button type="button" class="criteria-btn"  id="add_survey_btn" onclick="surveyEditUpdate()">Обновить анкету</button>
            <button type="button" class="criteria-btn"  id="send_email" onclick="send_email()">Отправить уведомление</button>
            <button type="button" class="modal_btn modal_btn-secondary" onclick="window.location.href='/surveys'">Отмена</button>
        </div>
    </div>

<div id="organizationModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Выбор организаций (ОМСУ)</h2>
        </div>
        <span class="modal-close" onclick="surveyEditCloseModal('organizationModal')"><i class="fas fa-xmark"></i></span>
        <div class="modal-body">
            <div class="organization-list" id="organizationList">
    @foreach (var organization in Model.AllOrganization)
    {
        var isSelected = Model.SelectedOrganizationIds.Contains(organization.Id);
        if (isSelected)
        {
            <div class="organization-item selected"
                 onclick="surveyEditToggleOrganizationSelection(this)"
                 data-id="@organization.Id"
                 data-name="@organization.Name"
                 data-selected="true">
                @organization.Name
            </div>
        }
        else
        {
            <div class="organization-item"
                 onclick="surveyEditToggleOrganizationSelection(this)"
                 data-id="@organization.Id"
                 data-name="@organization.Name"
                 data-selected="false">
                @organization.Name
            </div>
        }
    }
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="modal_btn modal_btn-primary" onclick="surveyEditSaveSelectedOrganization()">Сохранить</button>
            <button type="button" class="modal_btn modal_btn-secondary" onclick="surveyEditCloseModal('organizationModal')">Отмена</button>
        </div>
    </div>
</div>

<input type="hidden" id="surveyId" value="@Model.Survey.IdSurvey" />
<script>
    window.selectedOrganizationNames = @Html.Raw(selectedOrganizationNamesJson);
    if (typeof window.surveyEditInit === 'function') {
        window.setTimeout(function () {
            window.surveyEditInit();
        }, 0);
    }
</script>
 </body>
</html>
