@model MainProject.Services.Surveys.SurveyEditPageViewModel
@{
    ViewData["Title"] = "Обновление анкеты";
    var selectedOrganizationNamesJson = System.Text.Json.JsonSerializer.Serialize(Model.SelectedOrganizationNames);
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/survey-admin-pages.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="app-page app-page--narrow survey-editor-page" id="default_content" data-page="survey-update">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Обновление анкеты",
            Description = "Заполните форму ниже для обновления анкеты."
        })

    <section class="app-page__section app-page__stack">
        <h3 class="survey-editor-page__section-title">Шаг 1. Основные параметры</h3>

        <div class="form-group">
            <label for="surveyTitle">Название:</label>
            <input type="text" class="form-control" id="surveyTitle" value="@Model.Survey.NameSurvey" required />
            <div class="error-message" id="titleError"></div>
        </div>
        <div class="form-group">
            <label for="surveyDescription">Описание:</label>
            <textarea class="form-control" id="surveyDescription">@Model.Survey.Description</textarea>
        </div>
        <div class="form-group">
            <label for="startDate">Дата начала:</label>
            <input type="date" class="form-control" id="startDate" value="@Model.Survey.DateOpen.ToString("yyyy-MM-dd")" required />
            <div class="error-message" id="startDateError"></div>
        </div>
        <div class="form-group">
            <label for="endDate">Дата окончания:</label>
            <input type="date" class="form-control" id="endDate" value="@Model.Survey.DateClose.ToString("yyyy-MM-dd")" required />
            <div class="error-message" id="endDateError"></div>
        </div>

        <div class="form-group">
            <label>Организации:</label>
            <button type="button"
                    class="btn"
                    data-click-call="surveyEditOpenOrganizationModal">
                Выбрать ОМСУ
            </button>
            <input type="hidden" id="selectedOrganizationIds" value="@string.Join(",", Model.SelectedOrganizationIds)" />
            <div id="selectedOrganizationContainer" class="selected-organization" style="display: none;">
                <div id="selectedOrganizationList"></div>
            </div>
            <div class="error-message" id="organizationError">Выберите хотя бы одну организацию</div>
        </div>
    </section>

    <section class="app-page__section app-page__stack" id="two_step">
        <h3 class="survey-editor-page__section-title">Шаг 2. Критерии оценки</h3>

        <div id="cont_criteries">
            @foreach (var criterion in Model.Criteria)
            {
                <div class="form-group cont_criteries">
                    <label>Критерий оценки</label>
                    <input type="text" class="form-control criteriy" value="@criterion" required />
                    <div class="error-message"></div>
                </div>
            }
        </div>
    </section>

    <section class="app-page__section">
        <div class="criteria-buttons-container survey-editor-page__actions">
            <button type="button"
                    class="criteria-btn criteria-btn--info"
                    id="add_crit"
                    data-click-call="surveyEditAddCriteria">
                Добавить еще критерий
            </button>
            <button type="button"
                    class="criteria-btn criteria-btn--success"
                    id="add_survey_btn"
                    data-click-call="surveyEditUpdate">
                Обновить анкету
            </button>
            <button type="button"
                    class="criteria-btn"
                    id="send_email"
                    data-click-call="sendEmail">
                Отправить уведомление
            </button>
            <button type="button"
                    class="modal_btn modal_btn-secondary"
                    data-redirect-url="/surveys">
                Отмена
            </button>
        </div>
    </section>
</div>

<div id="organizationModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Выбор организаций (ОМСУ)</h2>
        </div>
        <span class="modal-close"
              data-click-call="surveyEditCloseModal"
              data-click-args='["organizationModal"]'>
            <i class="fas fa-xmark"></i>
        </span>
        <div class="modal-body">
            <div class="organization-list" id="organizationList">
    @foreach (var organization in Model.AllOrganization)
    {
        var isSelected = Model.SelectedOrganizationIds.Contains(organization.Id);
        if (isSelected)
        {
            <div class="organization-item selected"
                 data-click-call="surveyEditToggleOrganizationSelection"
                 data-click-pass-element="true"
                 data-id="@organization.Id"
                 data-name="@organization.Name"
                 data-selected="true">
                @organization.Name
            </div>
        }
        else
        {
            <div class="organization-item"
                 data-click-call="surveyEditToggleOrganizationSelection"
                 data-click-pass-element="true"
                 data-id="@organization.Id"
                 data-name="@organization.Name"
                 data-selected="false">
                @organization.Name
            </div>
        }
    }
            </div>
        </div>
        <div class="modal-footer">
            <button type="button"
                    class="modal_btn modal_btn-primary"
                    data-click-call="surveyEditSaveSelectedOrganization">
                Сохранить
            </button>
            <button type="button"
                    class="modal_btn modal_btn-secondary"
                    data-click-call="surveyEditCloseModal"
                    data-click-args='["organizationModal"]'>
                Отмена
            </button>
        </div>
    </div>
</div>

<input type="hidden" id="surveyId" value="@Model.Survey.IdSurvey" />
<template id="survey-edit-selected-organization-names">@selectedOrganizationNamesJson</template>

@section Scripts {
    @await Html.PartialAsync("~/Views/Survey/Partials/_AdminWorkflowScripts.cshtml")
    <script>
        const selectedOrganizationNamesElement = document.getElementById('survey-edit-selected-organization-names');
        window.selectedOrganizationNames = selectedOrganizationNamesElement
            ? JSON.parse(selectedOrganizationNamesElement.content.textContent.trim())
            : [];
        window.setTimeout(function () {
            if (typeof window.surveyEditInit === 'function') {
                window.surveyEditInit();
            }
        }, 0);
    </script>
}
