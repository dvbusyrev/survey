@model List<Survey>
@{
    ViewData["Title"] = "Архив анкет";
    var userOmsuId = ViewBag.UserOmsuId;
    var userId = Context.Session.GetInt32("id_user") ?? 0;
    var userRole = Context.Session.GetString("name_role") ?? "";
    var nameOmsu = Context.Session.GetString("name_omsu") ?? "";
    var nameUser = Context.Session.GetString("name_user") ?? "";
    var displayName = userRole == "Админ" && !string.IsNullOrWhiteSpace(nameOmsu) && !string.IsNullOrWhiteSpace(nameUser)
        ? $"{nameOmsu}: {nameUser}"
        : userRole;
    var searchTerm = ViewBag.SearchTerm ?? "";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/site2.css" asp-append-version="true" />
    <style>
        /* Стили такие же как в SurveyListUser.cshtml */
    </style>
</head>
<body>
    <div id="root"></div>

    <script src="/js/react.development.js"></script>
    <script src="/js/react-dom.development.js"></script>
    <script src="/js/babel.min.js"></script>
    <script src="~/js/components/Header.js"></script>
    <script src="~/js/components/Navigation.js"></script>
    <script src="~/js/components/Footer.js"></script>

    <script type="text/babel">
        const SurveyCard = ({ survey }) => {
            const formatDate = (dateString) => {
                if (!dateString) return 'Не указано';
                try {
                    const date = new Date(dateString);
                    return isNaN(date.getTime()) ? 'Не указано' : date.toLocaleDateString('ru-RU');
                } catch {
                    return 'Не указано';
                }
            };

            if (!survey) return null;

            return (
                <div className="survey-card" onClick={() => window.location.href = `/Survey/zapolnenie_anketi/${survey.id_survey}/${survey.id_omsu}`}>
                    <h3>{survey.name_survey || 'Без названия'}</h3>
                    <p>{survey.description || 'Нет описания'}</p>
                    <p>Дата заполнения: {formatDate(survey.completion_date)}</p>
                    <p>Статус: <span style={{ color: '#43a047' }}>завершена</span></p>
                    <div className="dates">
                        {formatDate(survey.date_open)} - {formatDate(survey.date_close)}
                    </div>
                </div>
            );
        };

        const ArchiveList = () => {
            const initialData = {
                surveys: @Html.Raw(Json.Serialize(Model ?? new List<Survey>())),
                userId: @userId,
                userRole: '@userRole',
                userOmsuId: @userOmsuId,
                searchTerm: '@searchTerm',
                displayName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayName))
            };

            const [searchTerm, setSearchTerm] = React.useState(initialData.searchTerm);
            const [loading, setLoading] = React.useState(false);
            const [error, setError] = React.useState(null);
            const [surveys, setSurveys] = React.useState(initialData.surveys || []);

            const loadData = async (search = '') => {
                setLoading(true);
                setError(null);
                try {
                    const response = await fetch(`/get_list_archive/${initialData.userId}?searchTerm=${search}`, {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });
                    
                    if (!response.ok) throw new Error('Ошибка загрузки данных');
                    
                    const data = await response.json();
                    setSurveys(data.accessibleSurveys || []);
                    
                } catch (err) {
                    console.error('Ошибка:', err);
                    setError(err.message);
                } finally {
                    setLoading(false);
                }
            };

            const handleSearch = (e) => {
                e.preventDefault();
                loadData(searchTerm);
            };

            const switchToActive = () => {
                window.location.href = `/survey_list_user/${initialData.userId}`;
            };

            if (initialData.userRole !== "user" && initialData.userRole !== "Админ") {
                return (
                    <div className="access-denied">
                        <h2>Доступ запрещён</h2>
                        <p>У вас нет прав для просмотра этой страницы.</p>
                    </div>
                );
            }

            return (
                <div className="page-container">
                    <Header userRole={initialData.userRole} displayName={initialData.displayName} />
                    <div className="admin-container">
                        <Navigation activeTab="archiv_surveys_for_user" userRole={initialData.userRole} userId={initialData.userId} />
                        <div id="content_admin">
                            <div className="note">
                                <h2>Архив анкет</h2>
                                <p>Ниже вы можете ознакомиться с архивными анкетами</p>
                            </div>

                            <div className="menu-bar">
                                <span onClick={switchToActive}>
                                    Активные анкеты
                                </span>
                                <span className="active-tab">
                                    Архив анкет
                                </span>
                            </div>

                            {error && <div className="error-message">{error}</div>}

                            <form onSubmit={handleSearch}>
                                <input
                                    type="text"
                                    className="search-box"
                                    value={searchTerm}
                                    onChange={(e) => setSearchTerm(e.target.value)}
                                    placeholder="Поиск по названию анкеты..."
                                />
                                <button type="submit" className="search-button">Поиск</button>
                            </form>

                            {loading ? (
                                <div className="loading">Загрузка...</div>
                            ) : (
                                <div className="survey-grid">
                                    {surveys.length > 0 ? (
                                        surveys.map((survey) => (
                                            <SurveyCard
                                                key={survey.id_survey}
                                                survey={survey}
                                            />
                                        ))
                                    ) : (
                                        <div className="no-surveys">
                                            <p>Нет архивных анкет</p>
                                        </div>
                                    )}
                                </div>
                            )}
                        </div>
                    </div>
                    <Footer />
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<ArchiveList />);
    </script>
</body>
</html>