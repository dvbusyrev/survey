@model List<MainProject.Models.Survey>
@using System.Security.Claims
@using System.Text.Json
@using MainProject.Infrastructure.Security
@{
    ViewData["Title"] = "Анкеты";
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var userId = int.TryParse(userIdClaim, out var parsedUserId) ? parsedUserId : 0;
    var nameOrganization = User.FindFirst("organization_name")?.Value ?? "";
    var nameUser = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var displayName = !string.IsNullOrWhiteSpace(nameOrganization) && !string.IsNullOrWhiteSpace(nameUser)
        ? $"{nameOrganization}: {nameUser}"
        : (!string.IsNullOrWhiteSpace(nameUser) ? nameUser : AppRoles.GetDisplayName(userRole));

    ViewBag.UserRole = userRole;
    ViewBag.UserId = userId;
    ViewBag.DisplayName = displayName;
    ViewBag.UserName = nameUser;
    ViewBag.OrganizationName = nameOrganization;

    var adminBootstrapJson = JsonSerializer.Serialize(new
    {
        userRole = ViewBag.UserRole ?? "",
        userId = ViewBag.UserId ?? 0,
        displayName = ViewBag.DisplayName ?? "",
        userName = ViewBag.UserName ?? "",
        organizationName = ViewBag.OrganizationName ?? "",
        selectedOrganizationNames = ViewBag.SelectedOrganizationNames ?? new List<string>(),
        surveys = Model ?? new List<MainProject.Models.Survey>()
    }, new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = true
    });
}

@Html.AntiForgeryToken()

<div id="root"></div>
<template id="admin-bootstrap-data">@adminBootstrapJson</template>

@section Scripts {
    <script>
        (function () {
            const bootstrapElement = document.getElementById('admin-bootstrap-data');
            window.__adminBootstrap = bootstrapElement
                ? JSON.parse(bootstrapElement.content.textContent.trim())
                : {};
        })();
    </script>
    @await Html.PartialAsync("~/Views/Survey/Partials/_AdminInlineAppScripts.cshtml")
}
