            // Подтверждение критериев
            function confirmCriteries() {
                const criteriaInputs = document.querySelectorAll('.criteriy');
                let allValid = true;
                
                criteriaInputs.forEach(input => {
                    if (!input.value.trim()) {
                        input.classList.add('invalid');
