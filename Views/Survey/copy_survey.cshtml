@model MainProject.Models.Survey
@{
    ViewData["Title"] = "Копирование анкеты";
    var currentDate = DateTime.Now.ToString("yyyy-MM-dd");
    var nextWeekDate = DateTime.Now.AddDays(7).ToString("yyyy-MM-dd");
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/survey-admin-pages.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="app-page app-page--narrow survey-editor-page" id="default_content" data-page="survey-copy">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Копирование анкеты",
            Description = "Создайте копию существующей анкеты с новыми датами активности."
        })

    <section class="app-page__section app-page__stack">
        <h3 class="survey-editor-page__section-title">Параметры копирования</h3>

        <div class="form-group">
            <label for="surveyTitle">Название анкеты:</label>
            <input type="text" class="form-control" id="surveyTitle" value="@Model.NameSurvey (Копия)" readonly />
        </div>

        <div class="form-group">
            <label for="startDate">Дата начала:</label>
            <input type="date" class="form-control" id="startDate" value="@currentDate" required />
        </div>

        <div class="form-group">
            <label for="endDate">Дата окончания:</label>
            <input type="date" class="form-control" id="endDate" value="@nextWeekDate" required />
        </div>

        <p class="survey-editor-page__note">Примечание: организации и критерии будут скопированы из оригинальной анкеты.</p>
    </section>

    <section class="app-page__section">
        <div class="button-container survey-editor-page__actions">
            <button type="button"
                    class="btn"
                    data-click-call="copySurvey"
                    data-click-args='[@Model.IdSurvey]'>Скопировать анкету</button>
        </div>
    </section>
</div>

@await Html.PartialAsync("~/Views/Shared/_OperationNotification.cshtml")
@await Html.PartialAsync("~/Views/Shared/_OperationLoadingOverlay.cshtml", "Идет копирование анкеты...")

@section Scripts {
    @await Html.PartialAsync("~/Views/Survey/Partials/_AdminWorkflowScripts.cshtml")
}
