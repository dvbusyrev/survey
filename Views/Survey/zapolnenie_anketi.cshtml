@model Survey
@{
    var userRole = Context.Session.GetString("name_role") ?? "";
    var nameOmsu = Context.Session.GetString("name_omsu") ?? "";
    var nameUser = Context.Session.GetString("name_user") ?? "";
    var displayName = !string.IsNullOrWhiteSpace(nameOmsu) && !string.IsNullOrWhiteSpace(nameUser)
        ? $"{nameOmsu}: {nameUser}"
        : userRole;
    var userId = Context.Session.GetInt32("id_user") ?? 0;
    var questions = ViewBag.Questions as List<Dictionary<string, object>> ?? new List<Dictionary<string, object>>();
    var surveyId = ViewBag.Id;
    var omsuId = ViewBag.Omsu_id;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Прохождение анкеты</title>

  <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/site2.css" asp-append-version="true" />
    <style>
        .admin-nav ul li:nth-child(1),
        .admin-nav ul li:nth-child(4),
        .admin-nav ul .users {
            display: none;
        }
        #users {display: none}
        .admin-nav ul li:nth-child(5) {
            display: none;
        }
        
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --text-main: #1f2937;
            --text-secondary: #6b7280;
            --border: #e5e7eb;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --transition: all 0.2s ease;
        }

        .survey-fill-container {
            padding: 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .back-button:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        .question-container {
            margin-bottom: 2rem;
            padding: 1.5rem;
            background-color: white;
            border-radius: 8px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
        }

        .comment-container {
            margin-top: 1rem;
            display: none;
        }

        .comment-container textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border);
            border-radius: 6px;
            resize: vertical;
            min-height: 100px;
        }

        .submit-container {
            margin-top: 2rem;
            text-align: center;
        }

        .submit-button {
            padding: 0.75rem 1.5rem;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .submit-button:hover {
            background-color: var(--primary-dark);
            box-shadow: var(--shadow-md);
        }

        .submit-button:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

        .error-message {
            color: var(--danger);
            margin-top: 0.5rem;
            font-weight: 6
        }

        .loading-spinner {
            width: 2rem;
            height: 2rem;
            border: 3px solid rgba(0, 0, 0, 0.1);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 0.75rem;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        @@media (max-width: 768px) {
            .survey-fill-container {
                padding: 1rem;
            }
            
    .btn_crit {
        width: 2.2rem;
        height: 2.2rem;
        font-size: 0.9rem;
    }
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script src="~/js/react.development.js"></script>
    <script src="~/js/react-dom.development.js"></script>
    <script src="~/js/babel.min.js"></script>
    <script src="~/js/components/Header.js"></script>
    <script src="~/js/components/Navigation.js"></script>
    <script src="~/js/components/Footer.js"></script>

    <script type="text/babel">
        const SurveyFillPage = () => {
            const [answers, setAnswers] = React.useState({});
            const [loading, setLoading] = React.useState(false);
            const [error, setError] = React.useState(null);
            const [isSubmitted, setIsSubmitted] = React.useState(false);
            
            const initialData = {
                userId: @userId,
                userRole: '@userRole',
                omsuId: @omsuId,
                surveyId: @surveyId,
                questions: @Html.Raw(Json.Serialize(questions)),
                displayName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayName))
            };

            const handleRatingClick = (questionId, rating) => {
                setAnswers(prev => ({
                    ...prev,
                    [questionId]: {
                        ...prev[questionId],
                        rating,
                        comment: rating < 5 ? prev[questionId]?.comment || '' : ''
                    }
                }));
            };

            const handleCommentChange = (questionId, comment) => {
                setAnswers(prev => ({
                    ...prev,
                    [questionId]: {
                        ...prev[questionId],
                        comment
                    }
                }));
            };

            const submitAnswers = async () => {
                try {
                    setLoading(true);
                    setError(null);
                    
                    // Проверяем, что все вопросы заполнены
                    const allQuestionsAnswered = initialData.questions.every(q => {
                        const questionId = q.id || q.Id;
                        const answer = answers[questionId];
                        return answer?.rating && (answer.rating >= 5 || answer.comment);
                    });
                    
                    if (!allQuestionsAnswered) {
                        throw new Error('Пожалуйста, ответьте на все вопросы. Для оценок ниже 5 требуется комментарий.');
                    }
                    
                    const response = await fetch('/api/submit_answers', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            surveyId: initialData.surveyId,
                            omsuId: initialData.omsuId,
                            answers: Object.entries(answers).map(([questionId, answer]) => ({
                                questionId,
                                rating: answer.rating,
                                comment: answer.comment || ''
                            }))
                        })
                    });

                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.error || 'Ошибка при отправке ответов');
                    }

                    setIsSubmitted(true);
                    setTimeout(() => {
                        window.location.href = '/survey/thank-you';
                    }, 2000);
                } catch (err) {
                    setError(err.message);
                } finally {
                    setLoading(false);
                }
            };

            const handleBackToList = () => {
                window.location.href = '/survey/list';
            };

            if (isSubmitted) {
                return (
                    <div className="success-message">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        <h2>Анкета успешно заполнена!</h2>
                        <p>Вы будете перенаправлены на страницу благодарности...</p>
                    </div>
                );
            }

            return (
                <div className="page-container">
                    <Header userRole={initialData.userRole} displayName={initialData.displayName} />
                    <div className="admin-container">
                        <Navigation activeTab="answers_tab" userRole={initialData.userRole} userId={initialData.userId} />
                        <div id="content_admin">
                            <div className="survey-fill-container">
                                <button onClick={handleBackToList} className="back-button">
                                    ← Вернуться к списку анкет
                                </button>
                                
                                <div className="note">
                                    <h2>Заполнение анкеты</h2>
                                    <p>Пожалуйста, оцените каждый вопрос по шкале от 1 до 5</p>
                                </div>
                                
                                {error && (
                                    <div className="error-message">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <line x1="12" y1="8" x2="12" y2="12"></line>
                                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                        </svg>
                                        {error}
                                    </div>
                                )}
                                
                                {initialData.questions.map((question, index) => {
                                    const questionId = question.id || question.Id || index;
                                    const questionText = question.text || question.Text || `Вопрос ${index + 1}`;
                                    const answer = answers[questionId] || {};
                                    
                                    return (
                                        <div className="question-container" key={questionId}>
                                            <h3>{questionText}</h3>
                                            <div className="rating-buttons">
                                                {[1, 2, 3, 4, 5].map(rating => (
                                                    <button
                                                        key={rating}
                                                        className={`btn_crit ${answer.rating === rating ? 'active' : ''}`}
                                                        onClick={() => handleRatingClick(questionId, rating)}
                                                    >
                                                        {rating}
                                                    </button>
                                                ))}
                                            </div>
                                            {answer.rating < 5 && (
                                                <div className="comment-container" style={{display: 'block'}}>
                                                    <textarea 
                                                        placeholder="Пожалуйста, укажите комментарий..." 
                                                        value={answer.comment || ''}
                                                        onChange={(e) => handleCommentChange(questionId, e.target.value)}
                                                    />
                                                </div>
                                            )}
                                        </div>
                                    );
                                })}
                                
                                <div className="submit-container">
                                    <button 
                                        onClick={submitAnswers} 
                                        className="submit-button"
                                        disabled={loading || !initialData.questions.every(q => {
                                            const questionId = q.id || q.Id;
                                            const answer = answers[questionId];
                                            return answer?.rating && (answer.rating >= 5 || answer.comment);
                                        })}
                                    >
                                        {loading ? (
                                            <>
                                                <span className="loading-spinner"></span>
                                                Отправка...
                                            </>
                                        ) : 'Отправить ответы'}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <Footer />
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<SurveyFillPage />);
    </script>
</body>
</html>