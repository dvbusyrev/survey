@model List<main_project.Models.HistorySurvey>
@{
    ViewData["Title"] = "Архив анкет";
}
        <link rel="stylesheet" href="~/css/site2.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/pages/admin-archives.css" asp-append-version="true" />
<div class="content archive-page">
    <div class="note">
        <h2>Архив анкет</h2>
        <p>На этой странице вы можете посмотреть архивные анкеты</p>
    </div>

<div class="filter-sort">
    <select id="filterSurvey" class="filter-select" 
            onclick="loadSurveyOptions()" 
            onchange="applySurveyFilter()">
        <option value="">Все анкеты</option>
    </select>
</div>




    <table id="data_table" class="all_table" style="overflow: visible">
        <thead>
            <tr class='table_tr'>
                <th>Название анкеты</th>
                <th>Описание</th>
                <th>Дата начала</th>
                <th>Дата окончания</th>
                <th>Вопросы</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var survey in Model)
    {
        <tr class="active">
            <td onclick="showAnswersModal(@survey.id_survey)">@survey.name_survey</td>
            <td onclick="showAnswersModal(@survey.id_survey)">@survey.description</td>
            <td onclick="showAnswersModal(@survey.id_survey)">@survey.date_begin.ToString("yyyy-MM-dd")</td>
            <td onclick="showAnswersModal(@survey.id_survey)">@survey.date_end.ToString("yyyy-MM-dd")</td>
            <td onclick="showAnswersModal(@survey.id_survey)">
                @if (!string.IsNullOrEmpty(survey.file_questions))
                {
                    try
                    {
                        var json = Newtonsoft.Json.Linq.JObject.Parse(survey.file_questions);
                        var questions = json["questions"] as Newtonsoft.Json.Linq.JArray;
                        @string.Join(", ", questions?.Select(q => q["text"]?.ToString()))
                    }
                    catch
                    {
                        <text>Ошибка формата</text>
                    }
                }
            </td>
            <td class="action-icons archive-actions">
<div class="icon-container" onclick="create_otchet_month(@survey.id_survey)" role="button" tabindex="0" aria-label="Сформировать отчёт">
  <span class="icon" aria-hidden="true">📋</span>
  <span class="icon-tooltip" data-tooltip="Сформировать отчёт по анкете">Сформировать отчёт</span>
</div>

                                        
<div class="icon-container" 
     onclick="copy_archive_survey(
       '@survey.name_survey', 
       '@survey.description', 
       '@survey.date_begin', 
       '@survey.date_end', 
       '@survey.file_questions'
     )" 
     role="button" 
     tabindex="0" 
     aria-label="Копировать и возобновить опрос">
    <span>📄</span>
    <span class="icon-tooltip">Копировать и возобновить</span>
</div>

            </td>
        </tr>
    }
    <tr id="none_result" style="display:none;">
        <td colspan="5" style="color:red; text-align:center;">Результаты не найдены!</td>
    </tr>
</tbody>
    </table>
</div>

@await Html.PartialAsync("~/Views/Shared/_AnswersModal.cshtml")

<script src="~/js/pages/admin-archives.js" asp-append-version="true"></script>


