@{
    ViewData["Title"] = "Добавление анкеты";
    var currentDate = DateTime.Now.ToString("yyyy-MM-dd");
    var nextWeekDate = DateTime.Now.AddDays(7).ToString("yyyy-MM-dd");
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/survey-admin-pages.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="app-page app-page--narrow survey-editor-page" id="default_content" data-page="survey-add">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Добавление анкеты",
            Description = "Заполните форму ниже для создания новой анкеты."
        })

    <section class="app-page__section app-page__stack">
        <h3 class="survey-editor-page__section-title">Шаг 1. Основные параметры</h3>

        <div class="form-group">
            <label for="surveyTitle">Название анкеты:</label>
            <input type="text" class="form-control" id="surveyTitle" placeholder="Введите название анкеты" required />
        </div>

        <div class="form-group">
            <label for="surveyDescription">Описание:</label>
            <input type="text" class="form-control" id="surveyDescription" placeholder="Введите описание анкеты" required />
        </div>

        <div class="form-group">
            <label for="startDate">Дата начала:</label>
            <input type="date" class="form-control" id="startDate" value="@currentDate" required />
        </div>

        <div class="form-group">
            <label for="endDate">Дата окончания:</label>
            <input type="date" class="form-control" id="endDate" value="@nextWeekDate" required />
        </div>

        <div class="form-group">
            <label>Выбор организаций:</label>
            <button type="button" class="btn" data-click-call="openOrganizationModal">Выбрать организацию</button>
        </div>

        <div class="selected-organization survey-editor-page__selected-organizations u-hidden" data-role="selected-organizations-container">
            <h4>Выбранные организации:</h4>
            <div class="survey-editor-page__selected-organizations-list" data-role="selected-organizations-list"></div>
        </div>
    </section>

    <section class="app-page__section app-page__stack survey-editor-page__criteria-step" data-role="criteria-step">
        <h3 class="survey-editor-page__section-title">Шаг 2. Критерии оценки</h3>

        <div class="survey-editor-page__criteria-list" data-role="criteria-list">
            <div class="form-group">
                <label for="criteriy1">Критерий оценки 1:</label>
                <input type="text" class="form-control criteriy" id="criteriy1" placeholder="Введите критерий оценки" required />
            </div>
        </div>
    </section>

    <section class="app-page__section">
        <div class="criteria-buttons-container survey-editor-page__actions">
            <button type="button" class="criteria-btn criteria-btn--success survey-editor-page__criteria-confirm" data-role="criteria-confirm" data-click-call="confirmCriteries">Подтвердить критерии</button>
            <button type="button" class="criteria-btn criteria-btn--info survey-editor-page__criteria-add" data-role="criteria-add" data-click-call="addRowCriteriy">Добавить критерий</button>
            <button type="button" class="criteria-btn criteria-btn--success survey-editor-page__survey-create u-hidden" data-role="survey-submit" data-click-call="addSurvey">Создать анкету</button>
            <button type="button" class="modal_btn modal_btn-secondary" data-redirect-url="/surveys">Отмена</button>
        </div>
    </section>
</div>

<div id="organizationModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="h2_modal">Выбор организаций</h2>
            <button type="button" class="modal-close" data-click-call="closeModal" data-click-args='["organizationModal"]'><i class="fas fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <div id="loadingOrgs" class="survey-loading-block">
                <div class="spinner"></div>
                <p class="survey-loading-label">Загрузка организаций...</p>
            </div>
            <div id="organizationList" class="organization-list u-hidden"></div>
        </div>
        <div class="modal-footer">
            <button type="button" class="modal_btn modal_btn-primary" data-click-call="saveSelectedOrganization">Сохранить</button>
            <button type="button" class="modal_btn modal_btn-secondary" data-click-call="closeModal" data-click-args='["organizationModal"]'>Отмена</button>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_OperationNotification.cshtml")
@await Html.PartialAsync("~/Views/Shared/_OperationLoadingOverlay.cshtml", "Идет обработка данных...")

@section Scripts {
    @await Html.PartialAsync("~/Views/Survey/Partials/_AdminWorkflowScripts.cshtml")
}
