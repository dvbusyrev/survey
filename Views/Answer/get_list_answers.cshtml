@model MainProject.Services.Answers.AnswerListPageViewModel
@{
    ViewData["Title"] = "Ответы на анкеты";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/admin-archives.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/answers.css" asp-append-version="true" />
}

<div class="app-page answers-page" id="default_content" data-page="answers-list">
    @await Html.PartialAsync(
        "~/Views/Shared/_PageIntro.cshtml",
        new MainProject.Models.PageIntroModel
        {
            Title = "Ответы на анкеты",
            Description = "На этой странице вы можете посмотреть ответы организаций на анкеты."
        })

    <section class="app-page__section">
        <div class="filter-sort">
            <select id="filterOrganization" class="filter-select"
                    data-focus-call="populateOrganizationOptions"
                    data-change-call="filterTable">
                <option value="">Все организации</option>
            </select>

            <select id="filterSurvey" class="filter-select"
                    data-focus-call="populateSurveyOptions"
                    data-change-call="filterTable">
                <option value="">Все анкеты</option>
            </select>
        </div>
    </section>

    <section class="app-page__section app-page__section--flush">
        <table data-role="main-table">
            <thead>
                <tr class="table_tr">
                    <th class="answers-page__th--start">Название организации <span class="sort-icon" id="sortIcon0"></span></th>
                    <th>Название анкеты <span class="sort-icon answers-page__sort-icon--hidden" id="sortIcon1"></span></th>
                    <th>Дата ответа <span class="sort-icon" id="sortIcon2"></span></th>
                    <th>Подпись</th>
                    <th class="answers-page__th--end">Ответы</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Answers.Any())
                {
                    foreach (var answer in Model.Answers)
                    {
                        <tr class="active answers-page__row"
                            data-click-call="showAnswersModal"
                            data-click-args='[@answer.IdSurvey, @answer.IdOrganization]'>
                            <td>@answer.OrganizationName</td>
                            <td>@answer.SurveyName</td>
                            <td>@answer.CompletionDate?.ToString("dd.MM.yyyy HH:mm:ss")</td>
                            <td>
                                @if (!answer.IsSigned)
                                {
                                    <span class="answers-page__unsigned-icon">❌</span>
                                }
                                else
                                {
                                    <span class="answers-page__signed-icon">✔️</span>
                                }
                            </td>
                            <td class="answers-page__view-link">Смотреть</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="table-empty-cell" id="none_result">Результаты не найдены!</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    @await Html.PartialAsync("~/Views/Shared/_AnswersModal.cshtml")
</div>

@section Scripts {
    @await Html.PartialAsync("~/Views/Shared/_AdminArchiveScripts.cshtml")
}
