@model main_project.Services.Answers.CheckAnswersPageViewModel

@{
    ViewData["Title"] = "Проверка ответов";
    var survey = Model.Survey;
    var answers = Model.Answers;
    var idOmsu = Model.IdOmsu;
}

@await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
<link rel="stylesheet" href="~/css/pages/answers.css" asp-append-version="true" />

<div class="content answers-page__check">
    @if (string.IsNullOrWhiteSpace(survey?.name_survey))
    {
        <div class="answers-page__error">
            <h2>Ошибка</h2>
            <p>Информация об анкете не найдена</p>
        </div>
    }
    else
    {
        <div class="note">
            <h2>Вы успешно прошли анкету!</h2>
            <p>На этой странице вы можете ознакомиться с ответами на анкету.</p>
        </div>

        <h3>@survey.name_survey</h3>
        
        @if (!string.IsNullOrEmpty(survey.description))
        {
            <p>@survey.description</p>
        }

        <div class="table-container">
            @if (answers == null || !answers.Any())
            {
                <p>Ответы не найдены</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Вопрос</th>
                            <th>Оценка</th>
                            <th>Комментарий</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var answer in answers)
                        {
                            <tr>
                                <td>@answer.DisplayQuestion</td>
                                <td>@answer.DisplayRating</td>
                                <td>@answer.Comment</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="answers-page__actions">
            <button class="answers-page__action-button" onclick="CSP(@survey.id_survey, @idOmsu)">Подписать</button>
            <button class="answers-page__action-button" onclick="create_otchet_for_me(@survey.id_survey, @idOmsu, 'file')">Скачать файл с анкетой</button>
        </div>

        <div id="block_btn_csp" class="answers-page__download-actions is-hidden">
            <button class="answers-page__action-button" onclick="create_otchet_for_me(@survey.id_survey, @idOmsu, 'archiv')">Скачать файл с анкетой и подписью</button>
        </div>
    }
</div>

<script src="~/js/pages/check-answers.js" asp-append-version="true"></script>
