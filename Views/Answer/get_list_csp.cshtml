@model main_project.Services.Answers.SurveySignaturePageViewModel
@{
    ViewData["Title"] = "Проверка подписей анкеты";
}

@await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
<link rel="stylesheet" href="~/css/pages/answers.css" asp-append-version="true" />

<div class="content answers-page__signatures" id="default_content">
    <div class="note">
        @if (!string.IsNullOrWhiteSpace(Model.SurveyName))
        {
            <h2>Просмотр подписания анкеты @Model.SurveyName</h2>
        <p>На данной странице вы можете посмотреть, какие организации прошли и (возможно) подписали анкету.</p>
        }
    </div>

    <div class="table-responsive">
        <table class="answers-page__signatures-table">
            <thead>
                <tr>
                    <th>Организация</th>
                    <th class="text-center">Статус прохождения</th>
                    <th class="text-center">Статус подписи</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.OrganizationName</td>
                            <td class="text-center">
                                <span class="status-badge @(item.IsCompleted ? "completed" : "not-completed")">
                                    @item.CompletionStatus
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="status-badge @(item.IsSigned ? "signed" : "not-signed")">
                                    @item.SignatureStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">
                            Нет данных о подписях организаций
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
