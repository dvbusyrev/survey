@model List<HistoryAnswer>
@{
    ViewData["Title"] = "Проверка подписей анкеты";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        .status-badge {
            padding: 0.35em 0.65em;
            font-size: 0.875em;
            font-weight: 700;
            border-radius: 0.25rem;
        }
        .completed {
            background-color: #d1e7dd;
            color: #0f5132;
        }
        .not-completed {
            background-color: #f8d7da;
            color: #842029;
        }
        .signed {
            background-color: #cfe2ff;
            color: #084298;
        }
        .not-signed {
            background-color: #fff3cd;
            color: #664d03;
        }

    </style>
</head>
<body>
    <div class="content" id="default_content">
    <p class="back-button" onClick="restoreSurveys()">← Вернуться на страницу списка анкет</p>
    <br />
        <div class="note">
            @if (ViewBag.SurveyName != null)
            {
                <h2>Просмотр подписания анкеты @ViewBag.SurveyName</h2>
            <p>На данной странице вы можете посмотреть, какие организации прошли и (возможно) подписали анкету.</p>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Организация</th>
                        <th class="text-center">Статус прохождения</th>
                        <th class="text-center">Статус подписи</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.name_omsu</td>
                                <td class="text-center">
                                    <span class="status-badge @(item.answers == "Пройдена" ? "completed" : "not-completed")">
                                        @item.answers
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="status-badge @(item.csp == "Подписана" ? "signed" : "not-signed")">
                                        @item.csp
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <i class="bi bi-exclamation-circle-fill me-2"></i>
                                Нет данных о подписях организаций
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>