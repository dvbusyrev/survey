<template id="admin-extension-modal-template">
  <div class="extension-modal-root admin-extension-modal-root">
    <h2 class="h2_modal admin-extension-modal-title">Продление анкеты</h2>
    <p data-role="survey-name" class="admin-extension-survey-name"></p>
    <div class="error-message admin-extension-error u-hidden" data-role="error"></div>
    <div data-role="rows-container" class="admin-extension-rows"></div>
    <p data-role="empty-state" class="u-hidden">Доступных организаций для продления не найдено.</p>
    <button type="button" data-role="add-row">+ Добавить организацию</button>
    <br />
    <div class="admin-extension-actions">
      <button type="button" data-role="submit" class="modal_btn modal_btn-primary">Продлить доступ</button>
      <button type="button" data-role="cancel" class="modal_btn modal_btn-secondary">Отмена</button>
    </div>
  </div>
</template>

<template id="admin-extension-modal-row-template">
  <div class="admin-extension-row">
    <div class="admin-extension-col">
      <label>Организация:</label>
      <select data-role="org-select" class="admin-extension-input" required></select>
    </div>
    <div class="admin-extension-col">
      <label>Дата окончания:</label>
      <input type="date" data-role="date-input" class="admin-extension-input" required />
    </div>
    <button type="button" data-role="remove-row" class="admin-extension-remove">
      Удалить
    </button>
  </div>
</template>

<template id="admin-statistics-template">
  <div class="admin-statistics-root">
    <div class="note">
      <h2>Статистика</h2>
    </div>
    <div class="chart-grid">
      <div class="chart-container">
        <h3 class="chart-title">Ответы по месяцам</h3>
        <div class="chart-wrapper"><canvas data-role="line-chart"></canvas></div>
      </div>
      <div class="chart-container">
        <h3 class="chart-title">Ответы по годам</h3>
        <div class="chart-wrapper"><canvas data-role="bar-chart"></canvas></div>
      </div>
      <div class="chart-container">
        <h3 class="chart-title">Распределение по типам анкет</h3>
        <div class="chart-wrapper"><canvas data-role="pie-chart"></canvas></div>
      </div>
      <div class="chart-container">
        <h3 class="chart-title">Средний балл организаций по годам</h3>
        <div class="chart-wrapper"><canvas data-role="radar-chart"></canvas></div>
      </div>
    </div>
  </div>
</template>
