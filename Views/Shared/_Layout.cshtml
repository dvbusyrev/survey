<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="~/images/icon.svg" asp-append-version="true" />
    <title>@(ViewData["Title"] ?? "Анкетирование")</title>
    @await Html.PartialAsync("~/Views/Shared/_BaseStyles.cshtml")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @RenderSection("PageStyles", required: false)
    @RenderSection("Head", required: false)
</head>
<body class="@(ViewData["BodyClass"] as string ?? string.Empty)">
    <div id="global-antiforgery-token" hidden aria-hidden="true">
        @Html.AntiForgeryToken()
    </div>
    @RenderBody()
    <script src="~/js/shared/app-antiforgery.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
