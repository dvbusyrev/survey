<template id="survey-user-page-template">
  <div class="page-container">
    <div data-component="header"></div>
    <div class="admin-container">
      <div data-component="navigation"></div>
      <div id="content_admin">
        <div class="content-wrapper">
          <div class="note">
            <h2 data-role="title"></h2>
            <p data-role="subtitle"></p>
          </div>

          <div class="menu-bar user-survey-tabs">
            <div class="menu-tab user-survey-tab" data-role="tab-active">
              Активные анкеты
              <span class="count-badge user-survey-count-badge" data-role="active-count">0</span>
            </div>
            <div class="menu-tab user-survey-tab" data-role="tab-archived">
              Архив анкет
            </div>
          </div>

          <div class="error-message u-hidden" data-role="error">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span data-role="error-text"></span>
          </div>

          <form class="search-container" data-role="search-form">
            <input type="text" class="search-box" data-role="search-input" placeholder="Поиск по названию анкеты..." />
            <div class="filter-sort">
              <select id="filterOrganization" class="filter-select" data-role="month-filter">
                <option value="">За все месяцы</option>
              </select>
              <select id="filterSurvey" class="filter-select" data-role="year-filter">
                <option value="">По всем годам</option>
              </select>
            </div>
            <label class="signed-filter u-hidden" data-role="signed-filter-wrap">
              <input type="checkbox" data-role="signed-filter-input" />
              Только подписанные
            </label>
          </form>

          <div class="loading u-hidden" data-role="loading">
            <div class="loading-spinner"></div>
            Загрузка анкет...
          </div>

          <div class="survey-grid" data-role="survey-grid"></div>

          <div class="pagination u-hidden" data-role="pagination">
            <button type="button" data-role="prev-page">Назад</button>
            <span data-role="page-label"></span>
            <button type="button" data-role="next-page">Вперед</button>
          </div>
        </div>
      </div>
    </div>
    <div data-role="fill-modal-host"></div>
    <div data-role="answers-modal-host"></div>
    <div data-component="footer"></div>
  </div>
</template>

<template id="survey-user-card-template">
  <div class="survey-card">
    <div class="survey-card-content" data-role="card-click">
      <h3 data-role="name"></h3>
      <p class="description" data-role="description"></p>
      <p class="date-info u-hidden" data-role="completion-info">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 14.66V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5.34"></path>
          <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"></polygon>
        </svg>
        <span data-role="completion-text"></span>
      </p>
      <p class="date-info" data-role="active-info">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        До завершения: <span class="time-left"></span>
      </p>
      <div class="signature-info u-hidden" data-role="signature">
        <svg class="signature-icon" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 17L10 13L13 16L18 11M20 12C20 16.4183 16.4183 20 12 20C7.58172 20 4 16.4183 4 12C4 7.58172 7.58172 4 12 4C16.4183 4 20 7.58172 20 12Z" stroke="#5c6bc0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"></polygon>
        </svg>
        Подпись:
        <span class="signature-status" data-role="signature-status"></span>
      </div>
      <div class="footer">
        <div class="dates">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <span data-role="period"></span>
        </div>
        <div class="status" data-role="status"></div>
      </div>
    </div>
  </div>
</template>

<template id="survey-user-empty-template">
  <div class="no-surveys">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="13" r="2"></circle>
      <line x1="13.45" y1="11.55" x2="15.5" y2="9.5"></line>
      <path d="M6.4 20.35a9 9 0 1 1 11.2 0"></path>
    </svg>
    <p>Нет анкет, соответствующих критериям фильтрации</p>
  </div>
</template>

<template id="survey-user-modal-template">
  <div class="modal modal--visible user-survey-modal" aria-hidden="false">
    <div class="modal-content user-survey-modal__content">
      <button type="button" class="modal-close" data-role="close-btn">
        <i class="fas fa-xmark"></i>
      </button>
      <div class="modal-header user-survey-modal__header u-hidden" data-role="title-wrap">
        <h2 class="h2_modal user-survey-modal__title" data-role="title"></h2>
      </div>
      <div class="modal-body user-survey-modal__body" data-role="body"></div>
    </div>
  </div>
</template>

<template id="survey-user-checkanswers-template">
  <div class="content" id="default_content">
    <div class="note">
      <h2>Вы успешно прошли анкету!</h2>
      <p>На этой странице вы можете ознакомиться с ответами на анкету.</p>
    </div>
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Вопрос</th>
            <th>Ответ</th>
            <th>Комментарий</th>
          </tr>
        </thead>
        <tbody data-role="answers-body"></tbody>
      </table>
    </div>
    <div class="button-container" data-role="sign-actions">
      <button class="submit-button" type="button" data-role="sign-btn">Подписать</button>
      <button class="submit-button" type="button" data-role="pdf-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span> </span>
        Скачать PDF с анкетой
      </button>
    </div>
    <div class="button-container u-hidden" data-role="signed-actions">
      <button class="submit-button" type="button" data-role="archive-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span> </span>
        Скачать архив (PDF + подпись)
      </button>
    </div>
  </div>
</template>

<template id="survey-user-fill-template">
  <div class="survey-fill-container">
    <div class="note">
      <h2 data-role="survey-title"></h2>
      <p data-role="survey-description"></p>
    </div>
    <div class="error-message u-hidden" data-role="fill-error"></div>
    <div data-role="questions-host"></div>
    <div class="submit-container">
      <button type="button" class="submit-button" data-role="submit-btn">Отправить ответы</button>
      <button type="button" class="modal_btn modal_btn-secondary user-survey-cancel-btn" data-role="cancel-btn">Отмена</button>
    </div>
  </div>
</template>

<template id="survey-user-fill-question-template">
  <div class="question-container">
    <h3 data-role="question-text"></h3>
    <div class="rating-buttons" data-role="rating-buttons"></div>
    <div class="comment-container u-hidden" data-role="comment-wrap">
      <label class="comment-label">Ваш комментарий</label>
      <textarea placeholder="Напишите комментарий"></textarea>
    </div>
  </div>
</template>

<template id="survey-user-fill-success-template">
  <div class="success-message">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
      <polyline points="22 4 12 14.01 9 11.01"></polyline>
    </svg>
    <h2>Анкета успешно заполнена!</h2>
    <p>Вы будете перенаправлены к результатам...</p>
  </div>
</template>

<template id="survey-user-checkanswers-page-template">
  <div class="answers-container">
    <h1 class="survey-title">
      Ответы на анкету: <span class="survey-name" data-role="survey-name"></span>
    </h1>
    <div class="signature-info u-hidden" data-role="signature-info">
      <div class="signature-icon-container">
        <svg class="signature-icon" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 17L10 13L13 16L18 11M20 12C20 16.4183 16.4183 20 12 20C7.58172 20 4 16.4183 4 12C4 7.58172 7.58172 4 12 4C16.4183 4 20 7.58172 20 12Z" stroke="#5c6bc0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          <polygon points="18 2 22 6 12 16 8 16 8 12 18 2"></polygon>
        </svg>
      </div>
      <div class="signature-label">Подпись:</div>
      <div class="signature-status" data-role="signature-status"></div>
    </div>
    <div class="empty-message u-hidden" data-role="empty-message">Нет данных для отображения</div>
    <div class="answers-content" data-role="answers-content"></div>
    <div class="submit-container user-survey-modal-actions">
      <button type="button" class="submit-button" data-role="pdf-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span> </span>
        Скачать PDF с анкетой
      </button>
    </div>
  </div>
</template>
