@model IEnumerable<MainProject.Domain.Entities.Organization>

@{
    ViewData["Title"] = "Архив организаций";
    ViewData["OrganizationSection"] = "archive";
    var organizations = Model ?? Array.Empty<MainProject.Domain.Entities.Organization>();
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/admin-archives.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/organization.css" asp-append-version="true" />
}

<div class="app-page organization-page archive-page" id="default_content">
    @await Html.PartialAsync("~/Web/Views/Organization/Partials/_OrganizationSubnav.cshtml")
    @await Html.PartialAsync(
        "~/Web/Views/Shared/_PageIntro.cshtml",
        new MainProject.Web.ViewModels.PageIntroModel
        {
            Title = "Архив организаций",
            Description = "Ниже представлена таблица с архивными организациями."
        })
    <section class="app-page__section app-page__section--flush">
        @await Html.PartialAsync("~/Web/Views/Organization/Partials/_ArchiveOrganizationTable.cshtml", organizations)
    </section>
</div>
