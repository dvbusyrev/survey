@model MainProject.Web.ViewModels.OrganizationListPageViewModel

@{
    ViewData["Title"] = "Список организаций";
    ViewData["OrganizationSection"] = "list";
    var organizations = Model?.Organizations ?? Array.Empty<MainProject.Domain.Entities.Organization>();
    var openAddOrganizationModal = Model?.OpenAddOrganizationModal ?? false;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/organization.css" asp-append-version="true" />
}

<div class="app-page organization-page" id="default_content" data-page="organization-list">
    @await Html.PartialAsync("~/Web/Views/Organization/Partials/_OrganizationSubnav.cshtml")
    @await Html.PartialAsync(
        "~/Web/Views/Shared/_PageIntro.cshtml",
        new MainProject.Web.ViewModels.PageIntroModel
        {
            Title = "Список организаций",
            Description = "Ниже представлена таблица с существующими организациями."
        })
    <div class="organization-toolbar app-page__toolbar">
        <button
            type="button"
            class="modal_btn modal_btn-primary"
            data-click-call="openAddOrganizationModal"
            data-fallback-url="/organizations/create">
            Добавить организацию
        </button>
    </div>
    <section class="app-page__section app-page__section--flush">
        @await Html.PartialAsync("~/Web/Views/Organization/Partials/_OrganizationTable.cshtml", organizations)
    </section>
</div>

@await Html.PartialAsync("~/Web/Views/Organization/Partials/_AddOrganizationModal.cshtml")
@await Html.PartialAsync("~/Web/Views/Organization/Partials/_EditOrganizationModal.cshtml")

@section Scripts {
    <script src="~/js/features/organization/organization-page.js" asp-append-version="true"></script>
    <script>
    (function(){
        if (@(openAddOrganizationModal.ToString().ToLowerInvariant())) {
            setTimeout(function(){
                if (typeof window.openAddOrganizationModal === 'function') {
                    window.openAddOrganizationModal();
                }
            }, 0);
        }
    })();
    </script>
}
