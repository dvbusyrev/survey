@model MainProject.Web.ViewModels.SurveySignaturePageViewModel
@{
    ViewData["Title"] = "Проверка подписей анкеты";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/answers.css" asp-append-version="true" />
}

<div class="app-page answers-page__signatures" id="default_content" data-page="survey-signatures">
    @await Html.PartialAsync(
        "~/Web/Views/Shared/_PageIntro.cshtml",
        new MainProject.Web.ViewModels.PageIntroModel
        {
            Title = string.IsNullOrWhiteSpace(Model.SurveyName) ? "Подписи анкеты" : $"Подписи анкеты {Model.SurveyName}",
            Description = "На этой странице вы можете посмотреть, какие организации прошли и подписали анкету."
        })

    <section class="app-page__section">
        <div class="table-responsive">
            <table class="answers-page__signatures-table">
                <thead>
                    <tr>
                        <th>Организация</th>
                        <th class="text-center">Статус прохождения</th>
                        <th class="text-center">Статус подписи</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.OrganizationName</td>
                                <td class="text-center">
                                    <span class="status-badge @(item.IsCompleted ? "completed" : "not-completed")">
                                        @item.CompletionStatus
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="status-badge @(item.IsSigned ? "signed" : "not-signed")">
                                        @item.SignatureStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">
                                Нет данных о подписях организаций
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
