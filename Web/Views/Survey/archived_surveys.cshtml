@model List<MainProject.Domain.Entities.ArchivedSurvey>
@{
    ViewData["Title"] = "Архив анкет";
    ViewData["SurveySection"] = "archive";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/pages/admin-archives.css" asp-append-version="true" />
}

<div class="app-page archive-page" id="default_content" data-page="surveys-archive">
    @await Html.PartialAsync("~/Web/Views/Survey/Partials/_SurveySubnav.cshtml")
    @await Html.PartialAsync(
        "~/Web/Views/Shared/_PageIntro.cshtml",
        new MainProject.Web.ViewModels.PageIntroModel
        {
            Title = "Архив анкет",
            Description = "На этой странице вы можете посмотреть архивные анкеты."
        })

    <section class="app-page__section">
        <div class="filter-sort">
            <select id="filterSurvey" class="filter-select"
                    data-focus-call="loadSurveyOptions"
                    data-change-call="applySurveyFilter">
                <option value="">Все анкеты</option>
            </select>
        </div>
    </section>

    <section class="app-page__section app-page__section--flush">
        <table class="surveys-table surveys-table--archive" data-role="main-table">
            <thead>
                <tr class='table_tr'>
                    <th class="table-th--start">Название анкеты</th>
                    <th>Описание</th>
                    <th class="table-col--date">Дата начала</th>
                    <th class="table-col--date">Дата окончания</th>
                    <th>Вопросы</th>
                    <th class="table-th--end table-col--actions">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var survey in Model)
                {
                    <tr class="active">
                        <td data-click-call="showAnswersModal" data-click-args='[@survey.IdSurvey]'>@survey.NameSurvey</td>
                        <td data-click-call="showAnswersModal" data-click-args='[@survey.IdSurvey]'>@survey.Description</td>
                        <td class="table-col--date" data-click-call="showAnswersModal" data-click-args='[@survey.IdSurvey]'>@survey.DateBegin.ToString("yyyy-MM-dd")</td>
                        <td class="table-col--date" data-click-call="showAnswersModal" data-click-args='[@survey.IdSurvey]'>@survey.DateEnd.ToString("yyyy-MM-dd")</td>
                        <td data-click-call="showAnswersModal" data-click-args='[@survey.IdSurvey]'>
                            @string.Join(", ", survey.Questions.Select(question => question.Text))
                        </td>
                        <td class="action-icons table-col--actions">
                            <div class="icon-container"
                                 data-click-call="createMonthlyReport"
                                 data-click-args='[@survey.IdSurvey]'
                                 role="button" tabindex="0" aria-label="Сформировать отчёт">
                                <span aria-hidden="true"><i class="fas fa-list-check"></i></span>
                                <span class="icon-tooltip" data-tooltip="Сформировать отчёт по анкете">Сформировать отчёт</span>
                            </div>

                            <div class="icon-container"
                                 data-click-call="copyArchivedSurvey"
                                 data-click-args='[@survey.IdSurvey]'
                                 role="button"
                                 tabindex="0"
                                 aria-label="Копировать и возобновить опрос">
                                <span><i class="fas fa-clipboard-copy"></i></span>
                                <span class="icon-tooltip">Копировать и возобновить</span>
                            </div>
                        </td>
                    </tr>
                }
                <tr id="none_result" class="is-hidden">
                    <td colspan="6" class="table-empty-cell">Результаты не найдены!</td>
                </tr>
            </tbody>
        </table>
    </section>

    @await Html.PartialAsync("~/Web/Views/Shared/_AnswersModal.cshtml")
</div>

@section Scripts {
    @await Html.PartialAsync("~/Web/Views/Shared/_AdminArchiveScripts.cshtml")
}
