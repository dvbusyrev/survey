@{
    var activeSection = (ViewData["UserSection"] as string ?? "list").ToLowerInvariant();
    var listActive = activeSection == "list";
    var archiveActive = activeSection == "archive";
}

<div class="menu-bar app-page__subnav" role="tablist" aria-label="Разделы пользователей">
    <a
        href="/users"
        class="menu-tab @(listActive ? "active-tab" : "")"
        role="tab"
        aria-selected="@(listActive ? "true" : "false")"
        data-tab-target="get_users">
        Список пользователей
    </a>
    <a
        href="/users/archive"
        class="menu-tab @(archiveActive ? "active-tab" : "")"
        role="tab"
        aria-selected="@(archiveActive ? "true" : "false")"
        data-tab-target="archived_users">
        Архив
    </a>
</div>
